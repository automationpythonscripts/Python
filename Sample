def create_html_report(data: List[Dict]) -> str:
    """Create HTML table report without embedded summary"""
    html = f"""
    <table border="1" style="border-collapse: collapse; width:115%; font-family: Calibri, sans-serif; font-size: 11pt;">
        <thead>
            <tr style="background-color: #FFD700; text-align: center; color: black;">
                <th style="padding:10px; width:6%;">Application Name</th>
                <th style="padding:10px; width:7.5%;">Server</th>
                <th style="padding:10px; width:27.5%;">Python Version for Executable Paths</th>
                <th style="padding:10px; width:9%;">Is Python 3.12 Executables available under /usr/bin/python*?</th>
                <th style="padding:10px; width:7.5%;">Is Python 2.7 associated rpm packages removed  from Server?</th>
                <th style="padding:10px; width:25%;">Is Python 2.7 Executables available under /usr/bin/python*?</th>
                <th style="padding:10px; width:7.5%;">Is Python Soft Link available or broken?<br>(Python Version)</th>
            </tr>
        </thead>
        <tbody>
    """
   
    df = pd.DataFrame(data)
    app_counts = df['Application'].value_counts(sort=False)
    current_app = ""
    
    for _, row in df.iterrows():
        align_style = "left"
        app_python = str(row["Python Version for Executable Paths"])
        
        # Apply both Python 3.12 (green) and Python 2.7 (red) highlighting
        highlighted_app = highlight_python_312_content(app_python)
        highlighted_app = highlight_python_27_content(highlighted_app)
        
        # Determine background colors based on Python version and error states
        if "Failed" in app_python or "Error" in app_python:
            bg_color = "#f8d7da"  # Light red for errors
        elif "2.7" in app_python:
            bg_color = "#f5c6cb"  # Light red background for Python 2.7 servers
        elif "3.12" in app_python:
            bg_color = "#d4edda"  # Light green for Python 3.12
        else:
            bg_color = "#ffffff"  # White for default

        html += "<tr>"
        if row['Application'] != current_app:
            count = app_counts[row['Application']]
            html += f'<td rowspan="{count}" style="font-weight: bold; text-align: center; vertical-align: middle;">{row["Application"]}</td>'
            current_app = row['Application']
       
        html += f'<td style="padding:6px; text-align: center; background-color: {bg_color};">{row["Server"]}</td>'
       
        cell_content = highlighted_app.replace('\n', '<br>')
        html += f'<td style="padding:6px; background-color: {bg_color}; text-align: {align_style}; white-space: pre-wrap;">{cell_content}</td>'
        
        # Add Python 3.12 installation column with conditional styling
        python312_status = str(row["Is Python 3.12 Executables available under /usr/bin/python*?"])
        if python312_status == "Yes":
            python312_bg_color = "#d4edda"  # Light Green for Yes
            python312_text_color = "black"
        elif python312_status == "No":
            python312_bg_color = "#f8d7da"  # Light Red for No
            python312_text_color = "black"
        else:
            python312_bg_color = bg_color  # Default for errors/connection failed
            python312_text_color = "black"
        html += f'<td style="padding:6px; text-align: center; background-color: {python312_bg_color}; color: {python312_text_color}; font-weight: bold;">{python312_status}</td>'
        
        # Add Python 2.7 RPM packages column with conditional styling
        rpm_status = str(row["Is Python 2.7 associated rpm packages removed  from Server?"])
        rpm_bg_color = "#d4edda" if rpm_status == "Yes" else "#f8d7da" if rpm_status == "No" else bg_color
        html += f'<td style="padding:6px; text-align: center; background-color: {rpm_bg_color}; font-weight: bold;">{rpm_status}</td>'
        
        # Add Python 2.7 Executables column with conditional styling
        python27_Executables_status = str(row["Is Python 2.7 Executables available under /usr/bin/python*?"])
        if python27_Executables_status.startswith("Yes"):
            python27_Executables_bg_color = "#f8d7da"  # Red for available (bad)
            python27_Executables_text_color = "black"
        elif python27_Executables_status == "No":
            python27_Executables_bg_color = "#d4edda"  # Green for not available (good)
            python27_Executables_text_color = "black"
        else:
            python27_Executables_bg_color = bg_color  # Default for errors/connection failed
            python27_Executables_text_color = "black"
        python27_Executables_content = python27_Executables_status.replace('\n', '<br>')
        html += f'<td style="padding:6px; text-align: center; background-color: {python27_Executables_bg_color}; color: {python27_Executables_text_color}; font-weight: bold;">{python27_Executables_content}</td>'
        
        # Add Python Soft Link column with conditional styling
        soft_link_status = str(row["Is Python Soft Link available or broken?\n(Python Version)"])
        if soft_link_status.startswith("Yes"):
            soft_link_bg_color = "#d4edda"  # Green for available
        elif soft_link_status.startswith("No"):
            soft_link_bg_color = "#f8d7da"  # Red for not available
        elif soft_link_status == "N/A":
            soft_link_bg_color = "#e9ecef"  # Light gray for N/A
        else:
            soft_link_bg_color = bg_color  # Default for errors/connection failed
        
        # Format soft link status content with line breaks for HTML display
        soft_link_content = soft_link_status.replace('\n', '<br>')
        html += f'<td style="padding:6px; text-align: center; background-color: {soft_link_bg_color}; font-weight: bold;">{soft_link_content}</td>'
        html += "</tr>"
   
    html += "</tbody></table>"
    return html


def create_excel_with_summary(data: List[Dict], excel_report_name: str):
    """Create Excel file with audit summary and detailed data"""
    try:
        # Calculate summary statistics
        summary = calculate_summary_stats(data)
        
        # Create Excel writer object
        with pd.ExcelWriter(excel_report_name, engine='openpyxl') as writer:
            # Create Summary Sheet
            summary_data = {
                'Metric': [
                    'Total Servers Audited based on App Wise',
                    'Servers that were having Python 3.12 as Default System Python',
                    'Servers that have Python 3.12 Executable under /usr/bin/python',
                    'Servers that Still having Old Python 2.7 in Operating System', 
                    'Servers that have Python 2.7 Executables under /usr/bin/python*',
                    'Python Soft Link Availability',
                    'Python Soft Link Checked Servers',
                    'Report Generated On'
                ],
                'Value': [
                    summary['total_servers'],
                    summary['python_312_servers'],
                    summary['python_312_installed_servers'],
                    summary['python_27_servers'],
                    summary['python_27_Executables_servers'],
                    summary['python_softlink_available'],
                    summary['python_softlink_checked_servers'],
                    datetime.now().strftime("%Y-%m-%d %H:%M:%S")
                ]
            }
            
            summary_df = pd.DataFrame(summary_data)
            summary_df.to_excel(writer, sheet_name='Audit Summary', index=False)
            
            # Create detailed data sheet
            final_df = pd.DataFrame(data).drop(columns=['Index'])
            final_df.to_excel(writer, sheet_name='Detailed Report', index=False)
            
            # Format the Summary sheet
            workbook = writer.book
            summary_sheet = writer.sheets['Audit Summary']
            
            # Set column widths
            summary_sheet.column_dimensions['A'].width = 35
            summary_sheet.column_dimensions['B'].width = 25
            
            # Add some styling
            from openpyxl.styles import Font, PatternFill, Alignment
            
            # Header styling
            header_font = Font(bold=True, size=12)
            header_fill = PatternFill(start_color='2E7D32', end_color='2E7D32', fill_type='solid')
            
            for cell in summary_sheet[1]:
                cell.font = Font(bold=True, size=12, color='FFFFFF')
                cell.fill = header_fill
                cell.alignment = Alignment(horizontal='center')
            
            # Data styling
            for row in summary_sheet.iter_rows(min_row=2, max_row=summary_sheet.max_row):
                for cell in row:
                    cell.alignment = Alignment(horizontal='left' if cell.column == 1 else 'center')
                    if 'Python 3.12' in str(cell.value):
                        cell.fill = PatternFill(start_color='D4EDDA', end_color='D4EDDA', fill_type='solid')
                    elif 'Python 2.7' in str(cell.value):
                        cell.fill = PatternFill(start_color='F8D7DA', end_color='F8D7DA', fill_type='solid')
            
            # Format the Detailed Report sheet
            detail_sheet = writer.sheets['Detailed Report']
            
            # Set column widths for detailed report
            detail_sheet.column_dimensions['A'].width = 30  # Application
            detail_sheet.column_dimensions['B'].width = 20  # Server
            detail_sheet.column_dimensions['C'].width = 50  # Python Version Details
            detail_sheet.column_dimensions['D'].width = 25  # Python 3.12 installed
            detail_sheet.column_dimensions['E'].width = 25  # RPM packages
            detail_sheet.column_dimensions['F'].width = 30  # Python 2.7 Executables
            detail_sheet.column_dimensions['G'].width = 25  # Soft Link
            
            # Header styling for detailed report
            for cell in detail_sheet[1]:
                cell.font = Font(bold=True, size=11, color='FFFFFF')
                cell.fill = header_fill
                cell.alignment = Alignment(horizontal='center')
            
            # Data alignment for detailed report - center align softlink column (G)
            for row in detail_sheet.iter_rows(min_row=2, max_row=detail_sheet.max_row):
                for cell in row:
                    if cell.column == 7:  # Column G (Soft Link column)
                        cell.alignment = Alignment(horizontal='center', vertical='center')
        
        print(f"💾 Excel report with audit summary saved: {excel_report_name}")
        
    except Exception as e:
        print(f"❌ Error creating Excel file: {e}")
        # Fallback to simple Excel creation
        final_df = pd.DataFrame(data).drop(columns=['Index'])
        final_df.to_excel(excel_report_name, index=False)
        print(f"💾 Basic Excel report saved: {excel_report_name}")


