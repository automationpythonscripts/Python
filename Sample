def calculate_summary_stats(data: List[Dict]) -> Dict:
    """Calculate summary statistics for the report"""
    total_servers = len(data)
    python_312_servers = 0
    python_312_installed_servers = 0
    python_27_servers = 0
    python_27_Executables_servers = 0
    python_softlink_available = 0
    python_softlink_checked_servers = 0
    
    for row in data:
        python_details = str(row.get("Python Version for Executable Paths", ""))
        softlink_status = str(row.get("Is Python Soft Link available or broken?\n(Python Version)", ""))
        python312_status = str(row.get("Is Python 3.12 Executables available under /usr/bin/python*?", ""))
        python27_Executables_status = str(row.get("Is Python 2.7 Executables available under /usr/bin/python*?", ""))
        app_name = str(row.get("Application", ""))
        
        # Check if server has Python 3.12 in the combined Python version details
        if "3.12" in python_details:
            python_312_servers += 1
        
        # Check if server has Python 3.12 installed using dedicated column
        if python312_status == "Yes":
            python_312_installed_servers += 1
        
        # Check if server has Python 2.7 in the combined Python version details
        if "2.7" in python_details:
            python_27_servers += 1
        
        # Check if server has Python 2.7 Executables available
        if python27_Executables_status.startswith("Yes"):
            python_27_Executables_servers += 1
        
        # Check Python soft link only for specific applications
        if app_name in PYTHON_SOFTLINK_CHECK_APPS:
            python_softlink_checked_servers += 1
            if softlink_status.startswith("Yes"):
                python_softlink_available += 1
    
    return {
        "total_servers": total_servers,
        "python_312_servers": python_312_servers,
        "python_312_installed_servers": python_312_installed_servers,
        "python_27_servers": python_27_servers,
        "python_27_Executables_servers": python_27_Executables_servers,
        "python_softlink_available": python_softlink_available,
        "python_softlink_checked_servers": python_softlink_checked_servers,
    }


def get_application_python(ssh: paramiko.SSHClient, app_name: str, system_python: str, python2_version: str, python3_version: str) -> str:
    # Start with system Python versions
    result_lines = []
    
    # Add system Python versions section
    system_section = []
    
    # Check system python with is_python_not_found function
    if system_python not in ["Not Installed", "Error", "Connection Failed", "Pending"]:
        if is_python_not_found(system_python):
            system_section.append(f"Version : Default Python Not Available\nPath : /usr/bin/python (Server Default Python Version)\n")
        else:
            system_section.append(f"Version : {system_python}\nPath : /usr/bin/python (Server Default Python Version)\n")
    elif system_python in ["Not Installed", "Error"]:
        system_section.append(f"Version : Default Python Not Available\nPath : /usr/bin/python (Server Default Python Version)\n")
    
    # Check python2 with is_python_not_found function
    if python2_version not in ["Not Installed", "Error", "Connection Failed", "Pending"]:
        if is_python_not_found(python2_version):
            system_section.append(f"Version : Python2 Not Available\nPath : /usr/bin/python2\n")
        else:
            system_section.append(f"Version : {python2_version}\nPath : /usr/bin/python2\n")
    elif python2_version in ["Not Installed", "Error"]:
        system_section.append(f"Version : Python2 Not Available\nPath : /usr/bin/python2\n")
    
    # Check python3 with is_python_not_found function
    if python3_version not in ["Not Installed", "Error", "Connection Failed", "Pending"]:
        if is_python_not_found(python3_version):
            system_section.append(f"Version : Python3 Not Available\nPath : /usr/bin/python3\n")
        else:
            system_section.append(f"Version : {python3_version}\nPath : /usr/bin/python3\n")
    elif python3_version in ["Not Installed", "Error"]:
        system_section.append(f"Version : Python3 Not Available\nPath : /usr/bin/python3\n")
    
    if system_section:
        result_lines.extend(system_section)
    
    # Check Application Python Paths for ALL servers, not just special apps
    for path in DEFAULT_RHEL_PYTHON_PATH:
        details = get_python_details(ssh, path)
        # Check if Python is available using is_python_not_found function
        if details['Python Version'] not in ["Not Installed", "Error"]:
            if is_python_not_found(details['Python Version']):
                result_lines.append(
                    f"Version : Default Python Not Available (Default RHEL Python Package Installer Version)\n"
                    f"Path : {path}\n"
                )
            else:
                result_lines.append(
                    f"Version : {details['Python Version']} (Default RHEL Python Package Installer Version)\n"
                    f"Path : {path}\n"
                )
        else:
            result_lines.append(
                f"Version : Default Python Not Available (Default RHEL Python Package Installer Version)\n"
                f"Path : {path}\n"
            )
    
    return "\n\n".join(result_lines) if result_lines else "No Python installations found"


def check_server(server: str, app_name: str, index: int) -> Dict:
    row = {
        "Index": index,
        "Application": app_name,
        "Server": server,
        "Python Version for Executable Paths": "Pending",
        "Is Python 3.12 Executables available under /usr/bin/python*?": "Pending",
        "Is Python 2.7 associated rpm packages removed  from Server?": "Pending",
        "Is Python 2.7 Executables available under /usr/bin/python*?": "Pending",
        "Is Python Soft Link available or broken?\n(Python Version)": "Pending"
    }
    
    try:
        ssh = paramiko.SSHClient()
        ssh.set_missing_host_key_policy(paramiko.AutoAddPolicy())
        ssh.connect(hostname=server, username=SSH_USER, password=SSH_PASS,
                    timeout=TIMEOUT, allow_agent=False, look_for_keys=False)
        
        shell = ssh.invoke_shell()
        time.sleep(2)
        if shell.recv_ready():
            shell.recv(10000)

        
        # Get Python versions
        sys_details = get_python_details(ssh, "python")
        system_python = sys_details["Python Version"]
        
        python2_details = get_python_details(ssh, "python2")
        python2_version = python2_details["Python Version"]
        
        python3_details = get_python_details(ssh, "python3")
        python3_version = python3_details["Python Version"]
        
        # Combine all Python version information
        row["Python Version for Executable Paths"] = get_application_python(ssh, app_name, system_python, python2_version, python3_version)
        
        # Check if Python 3.12 is installed
        row["Is Python 3.12 Executables available under /usr/bin/python*?"] = check_python312_installed(ssh)
        
        # Check Python 2.7 RPM packages
        row["Is Python 2.7 associated rpm packages removed  from Server?"] = check_python2_rpm_packages(ssh)
        
        # Check Python 2.7 Executables availability
        row["Is Python 2.7 Executables available under /usr/bin/python*?"] = check_python27_Executables_available(ssh)
        
        # Check Python soft link availability using application-specific logic
        row["Is Python Soft Link available or broken?\n(Python Version)"] = check_python_soft_link_by_app(ssh, app_name)
        
        ssh.close()
        logger.info(f"✅ {server} audited.")
       
    except Exception as e:
        err = "Connection Failed"
        row["Python Version for Executable Paths"] = err
        row["Is Python 3.12 Executables available under /usr/bin/python*?"] = "Connection Failed"
        row["Is Python 2.7 associated rpm packages removed  from Server?"] = "Connection Failed"
        row["Is Python 2.7 Executables available under /usr/bin/python*?"] = "Connection Failed"
        
        # Set soft link status to Connection Failed for apps that need checking, N/A for others
        if app_name in PYTHON_SOFTLINK_CHECK_APPS:
            row["Is Python Soft Link available or broken?\n(Python Version)"] = "Connection Failed"
        else:
            row["Is Python Soft Link available or broken?\n(Python Version)"] = "N/A"
            
        logger.error(f"❌ {server} failed: {str(e)[:60]}")
   
    return row


