def is_java_not_found(output: str) -> bool:
    """Enhanced detection for java not found messages"""
    output_lower = output.lower()
    return any(phrase in output_lower for phrase in [
        "ksh: java: not found",
        "command not found",
        "bash: java:",
        "java: command not found"
    ])

def parse_java_output(output: str) -> Dict:
    if not output or is_java_not_found(output):
        return {
            "Java Version": "Not Installed",
            "OpenJDK Runtime Environment": "Not Installed",
            "Vendor Details": "Not Installed"
        }

    lines = [line.strip() for line in output.splitlines() if line.strip()]
    version = "Not Available"
    runtime_env = "Not Available"
    vendor = "Not Available"

    if lines:
        first_line = lines[0].replace('"', '').strip()
        if "version" in first_line.lower():
            version = first_line.split("version")[-1].strip()
        else:
            version = first_line

    for line in lines:
        if "Runtime Environment" in line:
            runtime_env = line
        elif any(x in line for x in ["Server VM", "64-Bit", "OpenJDK", "Zulu", "Temurin"]):
            vendor = line

    return {
        "Java Version": version,
        "OpenJDK Runtime Environment": runtime_env,
        "Vendor Details": vendor
    }

def parse_aix_lslpp_output(lslpp_output: str) -> Dict:
    """Parse AIX lslpp output to extract Java version information"""
    try:
        lines = lslpp_output.split('\n')
        java_packages = []
        
        for line in lines:
            if 'java' in line.lower() and ('.' in line or 'jre' in line.lower() or 'jdk' in line.lower()):
                parts = line.split()
                if len(parts) >= 2:
                    package_name = parts[0]
                    version_info = parts[1] if len(parts) > 1 else "Unknown"
                    java_packages.append(f"{package_name}: {version_info}")
        
        if java_packages:
            # Enhanced vendor details for AIX
            first_package = java_packages[0]
            if "java8" in first_package.lower() or "1.8" in first_package:
                vendor_details = "IBM J9 VM (AIX Java 8 Runtime Environment)"
            elif "java11" in first_package.lower() or "11." in first_package:
                vendor_details = "IBM J9 VM (AIX Java 11 Runtime Environment)"
            else:
                vendor_details = f"IBM J9 VM (AIX Java Runtime - {first_package.split(':')[0]})"
                
            return {
                "Java Version": java_packages[0].split(':')[1].strip() if ':' in java_packages[0] else java_packages[0],
                "OpenJDK Runtime Environment": "AIX Java Runtime - " + "; ".join(java_packages[:2]),
                "Vendor Details": vendor_details
            }
        else:
            return {"Java Version": "Not Found", "OpenJDK Runtime Environment": "Not Found", "Vendor Details": "Not Found"}
            
    except Exception:
        return {"Java Version": "lslpp Parse Error", "OpenJDK Runtime Environment": "Error", "Vendor Details": "Error"}

def get_aix_java_vendor_name(ssh: paramiko.SSHClient, java_path: str) -> str:
    """Get Java vendor name for AIX systems"""
    try:
        # Try standard method first
        cmd = f'{java_path} -XshowSettings:properties 2>&1 | grep "java.vm.vendor"'
        _, stdout, stderr = execute_ssh_command_with_retry(ssh, cmd)
        result = stdout.read().decode('utf-8', errors='ignore').strip()
        
        if result and "=" in result:
            vendor = result.split("=")[-1].strip()
            return vendor if vendor else "IBM"
        
        # AIX fallback - check for IBM Java characteristics
        _, stdout, stderr = execute_ssh_command_with_retry(ssh, f'{java_path} -version')
        version_output = (stderr.read().decode('utf-8', errors='ignore') + 
                         stdout.read().decode('utf-8', errors='ignore')).strip()
        
        if "ibm" in version_output.lower() or "j9" in version_output.lower():
            return "IBM Corporation"
        elif "openjdk" in version_output.lower():
            return "OpenJDK"
        else:
            return "IBM (AIX Default)"
            
    except Exception:
        return "IBM (AIX Default)"

def extract_aix_vendor_details(output: str, vendor_details: str) -> str:
    """Extract enhanced AIX-specific vendor details from java -version output"""
    try:
        # Look for specific AIX Java patterns in the output
        if "IBM J9 VM" in output or "j9" in output.lower():
            # Extract build information if available
            if "build" in output.lower():
                build_match = re.search(r'build\s+([^,)]+)', output, re.IGNORECASE)
                if build_match:
                    build_info = build_match.group(1).strip()
                    if "1.8" in output or "java8" in output.lower():
                        return f"IBM J9 VM (build {build_info}, AIX Java 8)"
                    elif "11." in output or "java11" in output.lower():
                        return f"IBM J9 VM (build {build_info}, AIX Java 11)"
                    else:
                        return f"IBM J9 VM (build {build_info}, AIX Java Runtime)"
            
            # Fallback for IBM J9 without build info
            if "1.8" in output or "java8" in output.lower():
                return "IBM J9 VM (AIX Java 8 Runtime Environment)"
            elif "11." in output or "java11" in output.lower():
                return "IBM J9 VM (AIX Java 11 Runtime Environment)"
            else:
                return "IBM J9 VM (AIX Java Runtime Environment)"
        
        # If IBM is mentioned but not J9
        elif "ibm" in output.lower():
            if "1.8" in output:
                return "IBM AIX Java 8 Runtime Environment"
            elif "11." in output:
                return "IBM AIX Java 11 Runtime Environment"
            else:
                return "IBM AIX Java Runtime Environment"
        
        # Use original vendor details if no specific AIX patterns found
        return vendor_details if vendor_details != "Not Available" else "IBM AIX Java Runtime"
        
    except Exception:
        return vendor_details if vendor_details != "Not Available" else "IBM AIX Java Runtime"

def get_aix_java_info(ssh: paramiko.SSHClient) -> Dict:
    """Enhanced AIX Java detection using multiple methods"""
    try:
        logger.info("🔍 AIX Java Detection - Method 1: Direct java -version")
        # Method 1: Try direct java -version command
        _, stdout, stderr = execute_ssh_command_with_retry(ssh, 'java -version')
        output = (stderr.read().decode('utf-8', errors='ignore') + 
                  stdout.read().decode('utf-8', errors='ignore')).strip()
        
        if output and not any(x in output.lower() for x in ["permission denied", "cannot execute", "not found", "ksh:", "command not found"]):
            logger.info("✅ Method 1 Success: Found Java via direct command")
            base_info = parse_java_output(output)
            vendor_name = get_aix_java_vendor_name(ssh, "java")
            
            # Enhanced AIX vendor details extraction
            enhanced_vendor_details = extract_aix_vendor_details(output, base_info["Vendor Details"])
            
            return {
                "Java Version": base_info["Java Version"],
                "OpenJDK Runtime Environment": base_info["OpenJDK Runtime Environment"],
                "Vendor Details": enhanced_vendor_details,
                "Vendor Name": vendor_name
            }
        
        logger.info("🔍 AIX Java Detection - Method 2: lslpp command")
        # Method 2: Use lslpp to check installed Java packages
        _, stdout, stderr = execute_ssh_command_with_retry(ssh, 'lslpp -L "Java*" 2>/dev/null')
        lslpp_output = stdout.read().decode('utf-8', errors='ignore').strip()
        
        if lslpp_output and "not found" not in lslpp_output.lower():
            logger.info("✅ Method 2 Success: Found Java packages via lslpp")
            java_info = parse_aix_lslpp_output(lslpp_output)
            if java_info["Java Version"] != "Not Found":
                # Add vendor name for lslpp method
                java_info["Vendor Name"] = "IBM Corporation (AIX)"
                return java_info
        
        logger.info("🔍 AIX Java Detection - Method 3: Directory scanning")
        # Method 3: Check common AIX Java directories
        java_dirs = [
            "/usr/java*/bin/java",
            "/opt/IBM/java*/bin/java", 
            "/usr/IBM/java*/bin/java",
            "/opt/freeware/bin/java"
        ]
        
        for java_dir_pattern in java_dirs:
            _, stdout, stderr = execute_ssh_command_with_retry(ssh, f'ls {java_dir_pattern} 2>/dev/null | head -1')
            java_executable = stdout.read().decode('utf-8', errors='ignore').strip()
            
            if java_executable:
                logger.info(f"Found Java executable: {java_executable}")
                _, stdout, stderr = execute_ssh_command_with_retry(ssh, f'{java_executable} -version')
                output = (stderr.read().decode('utf-8', errors='ignore') + 
                          stdout.read().decode('utf-8', errors='ignore')).strip()
                
                if output and not any(x in output.lower() for x in ["permission denied", "cannot execute", "not found"]):
                    logger.info(f"✅ Method 3 Success: Working Java found at {java_executable}")
                    base_info = parse_java_output(output)
                    vendor_name = get_aix_java_vendor_name(ssh, java_executable)
                    
                    # Enhanced AIX vendor details extraction
                    enhanced_vendor_details = extract_aix_vendor_details(output, base_info["Vendor Details"])
                    
                    return {
                        "Java Version": base_info["Java Version"],
                        "OpenJDK Runtime Environment": base_info["OpenJDK Runtime Environment"],
                        "Vendor Details": enhanced_vendor_details,
                        "Vendor Name": vendor_name
                    }
        
        logger.info("🔍 AIX Java Detection - Method 4: PATH detection")
        # Method 4: Check if Java is in PATH using 'which'
        _, stdout, stderr = execute_ssh_command_with_retry(ssh, 'which java 2>/dev/null')
        which_java = stdout.read().decode('utf-8', errors='ignore').strip()
        
        if which_java and "/" in which_java:
            logger.info(f"Found Java in PATH: {which_java}")
            _, stdout, stderr = execute_ssh_command_with_retry(ssh, f'{which_java} -version')
            output = (stderr.read().decode('utf-8', errors='ignore') + 
                      stdout.read().decode('utf-8', errors='ignore')).strip()
            
            if output and not any(x in output.lower() for x in ["permission denied", "cannot execute", "not found"]):
                logger.info("✅ Method 4 Success: Working Java found via PATH")
                base_info = parse_java_output(output)
                vendor_name = get_aix_java_vendor_name(ssh, which_java)
                
                # Enhanced AIX vendor details extraction
                enhanced_vendor_details = extract_aix_vendor_details(output, base_info["Vendor Details"])
                
                return {
                    "Java Version": base_info["Java Version"],
                    "OpenJDK Runtime Environment": base_info["OpenJDK Runtime Environment"],
                    "Vendor Details": enhanced_vendor_details,
                    "Vendor Name": vendor_name
                }
        
        logger.warning("❌ All AIX Java detection methods failed")
        return {
            "Java Version": "Not Found on AIX",
            "OpenJDK Runtime Environment": "Not Found",
            "Vendor Details": "Not Found"
        }
        
    except Exception as e:
        logger.error(f"AIX Java detection error: {e}")
        return {
            "Java Version": "AIX Detection Error",
            "OpenJDK Runtime Environment": "Error",
            "Vendor Details": "Error"
        }

def get_java_details(ssh: paramiko.SSHClient, command: str) -> Dict:
    try:
        _, stdout, stderr = execute_ssh_command_with_retry(ssh, f"{command} -version")
        output = (stderr.read().decode('utf-8', errors='ignore') + 
                  stdout.read().decode('utf-8', errors='ignore')).strip()
       
        return parse_java_output(output)
       
    except Exception:
        return {
            "Java Version": "Error",
            "OpenJDK Runtime Environment": "Error",
            "Vendor Details": "Error"
        }

def get_java_vm_vendor(ssh: paramiko.SSHClient, command: str) -> str:
    """Get Java VM vendor using the specified command for Linux servers"""
    try:
        vendor_command = f"{command} -XshowSettings:properties -version 2>&1 | grep \"java.vm.vendor\" | awk -F= '{{print $2}}' | xargs"
        _, stdout, stderr = execute_ssh_command_with_retry(ssh, vendor_command)
        output = stdout.read().decode('utf-8').strip()
        
        if output and not is_java_not_found(output):
            return output
        else:
            return "Not Available"
            
    except Exception:
        return "Error"

def get_application_java(ssh: paramiko.SSHClient, app_name: str) -> str:
    if app_name not in SPECIAL_APPS:
        return "NA"
    
    result_lines = []
    for path in APPLICATION_JAVA_PATHS:
        details = get_java_details(ssh, path)
        vendor_name = get_java_vm_vendor(ssh, path)
        result_lines.append(
            f"Version : {details['Java Version']}\n"
            f"Runtime : {details['OpenJDK Runtime Environment']}\n"
            f"Vendor : {details['Vendor Details']}\n"
            f"Vendor Name : {vendor_name}\n"
            f"Path : {path}\n"
        )
    return "\n\n".join(result_lines)

@retry_with_backoff()
def establish_ssh_connection(server: str, username: str, password: str) -> paramiko.SSHClient:
    """
    Establish SSH connection with retry logic.
    
    Args:
        server: Server hostname
        username: SSH username
        password: SSH password
    
    Returns:
        paramiko.SSHClient: Connected SSH client
    """
    ssh = paramiko.SSHClient()
    ssh.set_missing_host_key_policy(paramiko.AutoAddPolicy())
    
    logger.info(f"🔗 Attempting SSH connection to {server}...")
    ssh.connect(
        hostname=server,
        username=username,
        password=password,
        timeout=TIMEOUT,
        allow_agent=False,
        look_for_keys=False
    )
    
    # Initialize shell to ensure connection is stable
    shell = ssh.invoke_shell()
    time.sleep(2)
    if shell.recv_ready():
        shell.recv(10000)
    shell.close()
    
    logger.info(f"✅ SSH connection established to {server}")
    return ssh

def check_server(server: str, app_name: str, index: int) -> Dict:
    username, password = get_credentials(app_name)
    is_aix = is_aix_server(server)
   
    row = {
        "Index": index,
        "Application": app_name,
        "Server": server,
        "System Java Version": "Pending",
        "System OpenJDK Runtime": "Pending",
        "System Vendor OpenJDK Details": "Pending",
        "System Vendor Name": "Pending",
        "Application Java Details": "Pending"
    }
   
    try:
        # Use retry-enabled SSH connection
        ssh = establish_ssh_connection(server, username, password)
        ssh.connect(
            hostname=server,
            username=username,
            password=password,
            timeout=TIMEOUT,
            allow_agent=False,
            look_for_keys=False
        )
       
        shell = ssh.invoke_shell()
        time.sleep(2)
        if shell.recv_ready():
            shell.recv(10000)

        if is_aix:
            # Use AIX-specific Java detection
            sys_details = get_aix_java_info(ssh)
            row["System Vendor Name"] = sys_details.get("Vendor Name", "AIX System")
        else:
            # Use standard Java detection for Linux
            sys_details = get_java_details(ssh, "java")
            row["System Vendor Name"] = get_java_vm_vendor(ssh, "java")
            
        row["System Java Version"] = sys_details["Java Version"]
        row["System OpenJDK Runtime"] = sys_details["OpenJDK Runtime Environment"]
        row["System Vendor OpenJDK Details"] = sys_details["Vendor Details"]
        row["Application Java Details"] = get_application_java(ssh, app_name)
       
        ssh.close()
        logger.info(f"✅ {server} ({'AIX' if is_aix else 'Linux'}) audited.")
       
    except Exception as e:
        err = "Connection Failed"
        row["System Java Version"] = err
        row["System OpenJDK Runtime"] = err
        row["System Vendor OpenJDK Details"] = err
        row["System Vendor Name"] = err
        row["Application Java Details"] = err
        logger.error(f"❌ {server} failed: {str(e)[:80]}")
   
    return row

def highlight_version(val, vendor_name="", runtime=""):
    if not isinstance(val, str):
        return val

    # Red Highlight - Critical (Red Hat 11.0.x)
    if "Red Hat" in vendor_name and "Red_Hat-11.0" in runtime:
        return f'<span style="background-color: #FF6B6B; color: white; font-weight: bold; padding: 3px 6px; border-radius: 4px;">{val}</span>'

    # Yellow Highlight - Warning (Red Hat 1.8)
    if "Red Hat" in vendor_name and re.search(r'1\.8\.0_', runtime):
        return f'<span style="background-color: #FFEB3B; color: black; font-weight: bold; padding: 3px 6px; border-radius: 4px;">{val}</span>'

    return val

def highlight_application_java_details(app_java_details):
    """Enhanced highlighting function specifically for Application Java Details"""
    if not isinstance(app_java_details, str) or app_java_details in ["NA", "Pending", "Error", "Connection Failed"]:
        return app_java_details
    
    # Split the content into sections (each path's details)
    sections = app_java_details.split('\n\n')
    highlighted_sections = []
    
    for section in sections:
        if not section.strip():
            continue
            
        lines = section.split('\n')
        highlighted_lines = []
        
        # Parse each section to extract version, runtime, vendor info
        version_line = ""
        runtime_line = ""
        vendor_line = ""
        vendor_name_line = ""
        path_line = ""
        
        for line in lines:
            line = line.strip()
            if line.startswith("Version :"):
                version_line = line
            elif line.startswith("Runtime :"):
                runtime_line = line
            elif line.startswith("Vendor :"):
                vendor_line = line
            elif line.startswith("Vendor Name :"):
                vendor_name_line = line
            elif line.startswith("Path :"):
                path_line = line
        
        # Extract values for highlighting logic
        version_value = version_line.replace("Version :", "").strip()
        runtime_value = runtime_line.replace("Runtime :", "").strip()
        vendor_value = vendor_line.replace("Vendor :", "").strip()
        vendor_name_value = vendor_name_line.replace("Vendor Name :", "").strip()
        
        # Apply highlighting logic based on vendor and version patterns
        should_highlight_red = ("Red Hat" in vendor_name_value and "Red_Hat-11.0" in runtime_value)
        should_highlight_yellow = ("Red Hat" in vendor_name_value and re.search(r'1\.8\.0_', runtime_value))
        
        # Apply highlighting to each line if conditions are met
        if should_highlight_red:
            if version_line:
                highlighted_lines.append(f'<span style="background-color: #FF6B6B; color: white; font-weight: bold; padding: 3px 6px; border-radius: 4px;">{version_line}</span>')
            if runtime_line:
                highlighted_lines.append(f'<span style="background-color: #FF6B6B; color: white; font-weight: bold; padding: 3px 6px; border-radius: 4px;">{runtime_line}</span>')
            if vendor_line:
                highlighted_lines.append(f'<span style="background-color: #FF6B6B; color: white; font-weight: bold; padding: 3px 6px; border-radius: 4px;">{vendor_line}</span>')
            if vendor_name_line:
                highlighted_lines.append(f'<span style="background-color: #FF6B6B; color: white; font-weight: bold; padding: 3px 6px; border-radius: 4px;">{vendor_name_line}</span>')
            if path_line:
                highlighted_lines.append(path_line)  # Path doesn't need highlighting
        elif should_highlight_yellow:
            if version_line:
                highlighted_lines.append(f'<span style="background-color: #FFEB3B; color: black; font-weight: bold; padding: 3px 6px; border-radius: 4px;">{version_line}</span>')
            if runtime_line:
                highlighted_lines.append(f'<span style="background-color: #FFEB3B; color: black; font-weight: bold; padding: 3px 6px; border-radius: 4px;">{runtime_line}</span>')
            if vendor_line:
                highlighted_lines.append(f'<span style="background-color: #FFEB3B; color: black; font-weight: bold; padding: 3px 6px; border-radius: 4px;">{vendor_line}</span>')
            if vendor_name_line:
                highlighted_lines.append(f'<span style="background-color: #FFEB3B; color: black; font-weight: bold; padding: 3px 6px; border-radius: 4px;">{vendor_name_line}</span>')
            if path_line:
                highlighted_lines.append(path_line)  # Path doesn't need highlighting
        else:
            # No highlighting needed
            highlighted_lines = lines
        
        highlighted_sections.append('\n'.join(highlighted_lines))
    
    return '\n\n'.join(highlighted_sections)

def get_audited_summary(data: List[Dict]) -> Dict:
    df = pd.DataFrame(data)
    total_servers = df['Server'].nunique()
    
    immediate = df[
        (df['System Vendor Name'].str.contains('Red Hat', na=False)) & 
        (df['System OpenJDK Runtime'].str.contains('Red_Hat-11.0', na=False))
    ]['Server'].nunique()
    
    upgrade = df[
        (df['System Vendor Name'].str.contains('Red Hat', na=False)) & 
        (df['System OpenJDK Runtime'].str.contains(r'1\.8\.0_', na=False))
    ]['Server'].nunique()
    
    return {
        "Total Servers Audited": total_servers,
        "Servers that Need Immediate Attention (Red Hat OpenJDK 11 - EOL)": immediate,
        "Servers Requiring Upgrade (Red Hat OpenJDK 8 - EOL Nov 2026)": upgrade
    }

