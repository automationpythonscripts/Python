# ====================== RETRY DECORATOR ======================

def retry_with_backoff(max_attempts=MAX_RETRY_ATTEMPTS, base_delay=BASE_RETRY_DELAY, 
                      max_delay=MAX_RETRY_DELAY, backoff_multiplier=RETRY_BACKOFF_MULTIPLIER):
    """
    Decorator that implements exponential backoff retry logic for connection failures.
    
    Args:
        max_attempts: Maximum number of retry attempts
        base_delay: Initial delay between retries in seconds
        max_delay: Maximum delay between retries in seconds
        backoff_multiplier: Multiplier for exponential backoff
    """
    def decorator(func):
        @wraps(func)
        def wrapper(*args, **kwargs):
            last_exception = None
            
            for attempt in range(max_attempts):
                try:
                    return func(*args, **kwargs)
                except (paramiko.AuthenticationException, 
                       paramiko.SSHException, 
                       paramiko.NoValidConnectionsError,
                       ConnectionError,
                       TimeoutError,
                       OSError) as e:
                    last_exception = e
                    
                    if attempt == max_attempts - 1:  # Last attempt
                        logger.error(f"❌ Final attempt failed for {func.__name__}: {str(e)[:100]}")
                        raise e
                    
                    # Calculate delay with exponential backoff and jitter
                    delay = min(base_delay * (backoff_multiplier ** attempt), max_delay)
                    jitter = random.uniform(0.1, 0.3) * delay  # Add 10-30% jitter
                    total_delay = delay + jitter
                    
                    logger.warning(f"⚠️ Attempt {attempt + 1}/{max_attempts} failed for {func.__name__}: {str(e)[:80]}")
                    logger.info(f"🔄 Retrying in {total_delay:.1f} seconds...")
                    time.sleep(total_delay)
                except Exception as e:
                    # For non-connection related errors, don't retry
                    logger.error(f"❌ Non-retryable error in {func.__name__}: {str(e)[:100]}")
                    raise e
            
            # This should never be reached, but just in case
            raise last_exception
        return wrapper
    return decorator

def execute_ssh_command_with_retry(ssh, command, timeout=COMMAND_TIMEOUT):
    """
    Execute SSH command with retry logic for timeout errors.
    
    Args:
        ssh: paramiko.SSHClient instance
        command: Command to execute
        timeout: Command timeout in seconds
    
    Returns:
        tuple: (stdin, stdout, stderr)
    """
    max_cmd_attempts = 2
    for attempt in range(max_cmd_attempts):
        try:
            return ssh.exec_command(command, timeout=timeout)
        except Exception as e:
            if attempt == max_cmd_attempts - 1:
                logger.error(f"❌ Command execution failed after {max_cmd_attempts} attempts: {command[:50]}")
                raise e
            logger.warning(f"⚠️ Command timeout, retrying: {command[:50]}")
            time.sleep(1)

