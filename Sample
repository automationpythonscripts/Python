            <th style="padding:10px;">Server</th>
            <th style="padding:10px;">System Java Version</th>
            <th style="padding:10px;">System OpenJDK Runtime</th>
            <th style="padding:10px;">System Vendor OpenJDK Details</th>
            <th style="padding:10px;">System Vendor Name</th>
            <th style="padding:10px;">Oracle Client Paths Java Version Details</th>
        </tr></thead><tbody>"""
   
    df = pd.DataFrame(data)
    app_counts = df['Application'].value_counts(sort=False)
    current_app = ""
   
    for _, row in df.iterrows():
        is_special = row['Application'] in SPECIAL_APPS
        align_style = "left" if is_special else "center"
        app_java = str(row["Application Java Details"])
        bg_color = "#f8d7da" if "Failed" in app_java or "Error" in app_java else "#ffffff"

        html += "<tr>"
        if row['Application'] != current_app:
            count = app_counts[row['Application']]
            html += f'<td rowspan="{count}" style="background-color: #E8F5E9; font-weight: bold; text-align: center; vertical-align: middle;">{row["Application"]}</td>'
            current_app = row['Application']
       
        html += f'<td style="padding:6px; text-align: center;">{row["Server"]}</td>'
        
        # Apply highlighting to System Java Version
        highlighted_version = highlight_version(row["System Java Version"], row["System Vendor Name"], row["System OpenJDK Runtime"])
        html += f'<td style="padding:6px; text-align: center;">{highlighted_version}</td>'
        
        # Apply highlighting to System OpenJDK Runtime
        highlighted_runtime = highlight_version(row["System OpenJDK Runtime"], row["System Vendor Name"], row["System OpenJDK Runtime"])
        html += f'<td style="padding:6px; text-align: left; white-space: pre-wrap;">{highlighted_runtime}</td>'
        
        # Apply highlighting to System Vendor OpenJDK Details
        highlighted_vendor_details = highlight_version(row["System Vendor OpenJDK Details"], row["System Vendor Name"], row["System OpenJDK Runtime"])
        html += f'<td style="padding:6px; text-align: left; white-space: pre-wrap;">{highlighted_vendor_details}</td>'
        
        # Apply highlighting to System Vendor Name
        highlighted_vendor_name = highlight_version(row["System Vendor Name"], row["System Vendor Name"], row["System OpenJDK Runtime"])
        html += f'<td style="padding:6px; text-align: center;">{highlighted_vendor_name}</td>'
        # Apply comprehensive highlighting to Application Java Details
        highlighted_app_java = highlight_application_java_details(app_java)
        cell_content = highlighted_app_java.replace('\n', '<br>')
        html += f'<td style="padding:6px; background-color: {bg_color}; text-align: {align_style}; white-space: pre-wrap;">{cell_content}</td>'
        html += "</tr>"
    html += "</tbody></table>"
    return html

