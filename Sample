# ====================== RETRY DECORATOR ======================
def retry_with_backoff(max_attempts=MAX_RETRY_ATTEMPTS, base_delay=BASE_RETRY_DELAY, 
                      max_delay=MAX_RETRY_DELAY, backoff_multiplier=RETRY_BACKOFF_MULTIPLIER):
    def decorator(func):
        @wraps(func)
        def wrapper(*args, **kwargs):
            last_exception = None
            for attempt in range(max_attempts):
                try:
                    return func(*args, **kwargs)
                except (paramiko.AuthenticationException, paramiko.SSHException, 
                        paramiko.NoValidConnectionsError, ConnectionError, 
                        TimeoutError, OSError) as e:
                    last_exception = e
                    if attempt == max_attempts - 1:
                        server = args[0] if args else "unknown"
                        logger.error(f"❌ Final attempt failed for {func.__name__} on {server}: {str(e)[:100]}")
                        raise
                    delay = min(base_delay * (backoff_multiplier ** attempt), max_delay)
                    jitter = random.uniform(0.1, 0.3) * delay
                    total_delay = delay + jitter
                    logger.warning(f"⚠️ Attempt {attempt + 1}/{max_attempts} failed for {server}: {str(e)[:80]}")
                    logger.info(f"🔄 Retrying in {total_delay:.1f} seconds...")
                    time.sleep(total_delay)
                except Exception as e:
                    logger.error(f"❌ Non-retryable error in {func.__name__}: {str(e)[:100]}")
                    raise
            raise last_exception
        return wrapper
    return decorator

def execute_ssh_command_with_retry(ssh, command, timeout=COMMAND_TIMEOUT):
    for attempt in range(2):
        try:
            return ssh.exec_command(command, timeout=timeout)
        except Exception as e:
            if attempt == 1:
                raise
            logger.warning(f"⚠️ Command timeout, retrying: {command[:50]}")
            time.sleep(1)

