def create_html_report(data: List[Dict]) -> str:
    # Same as before (kept unchanged except removing credential column)
    html = """<table border="1" style="border-collapse: collapse; width:100%; font-family: Calibri, sans-serif; font-size: 11pt;">
        <thead><tr style="background-color: #2E7D32; text-align: center; color: white;">
