def get_python_details(ssh: paramiko.SSHClient, command: str) -> Dict:
    try:
        _, stdout, stderr = ssh.exec_command(f"{command} --version", timeout=10)
        output = (stdout.read().decode('utf-8') + stderr.read().decode('utf-8')).strip()
        
        # Filter out various error conditions
        error_patterns = [
            "command not found",
            "bash: python:",
            "no such file or directory",
            f"bash: {command}: no such file or directory"
        ]
        
        if not output or any(pattern in output.lower() for pattern in error_patterns):
            return {"Python Version": "Not Installed"}
        
        version = parse_python_output(output)
        return {"Python Version": version}
    except Exception:
        return {"Python Version": "Error"}




def highlight_python_312_content(content: str) -> str:
    """Highlight Python 3.12 content with green background"""
    if "3.12" in content:
        # Replace Python 3.12 mentions with highlighted version
        import re
        pattern = r'(Python\s+3\.12[.\d]*)'
        highlighted_content = re.sub(pattern, r'<span style="background-color: #28a745; color: white; padding: 2px 4px; border-radius: 3px; font-weight: bold;">\1</span>', content)
        return highlighted_content
    return content

