def get_java_details(ssh: paramiko.SSHClient, command: str) -> Dict:
    try:
        _, stdout, stderr = execute_ssh_command_with_retry(ssh, f"{command} -version")
        output = (stderr.read().decode('utf-8', errors='ignore') + stdout.read().decode('utf-8', errors='ignore')).strip()
        return parse_java_output(output)
    except Exception:
        return {"Java Version": "Error", "OpenJDK Runtime Environment": "Error", "Vendor Details": "Error"}

def get_java_vm_vendor(ssh: paramiko.SSHClient, command: str) -> str:
    try:
        vendor_cmd = f"{command} -XshowSettings:properties -version 2>&1 | grep 'java.vm.vendor' | awk -F= '{{print $2}}' | xargs"
        _, stdout, _ = execute_ssh_command_with_retry(ssh, vendor_cmd)
        return stdout.read().decode('utf-8').strip() or "Not Available"
    except Exception:
        return "Not Available"

def get_application_java(ssh: paramiko.SSHClient, app_name: str) -> str:
    if app_name not in SPECIAL_APPS:
        return "NA"
    result_lines = []
    for path in APPLICATION_JAVA_PATHS:
        details = get_java_details(ssh, path)
        vendor_name = get_java_vm_vendor(ssh, path)
        result_lines.append(f"Version : {details['Java Version']}\nRuntime : {details['OpenJDK Runtime Environment']}\nVendor : {details['Vendor Details']}\nVendor Name : {vendor_name}\nPath : {path}\n")
    return "\n\n".join(result_lines)

@retry_with_backoff()
def establish_ssh_connection(server: str, username: str, password: str) -> paramiko.SSHClient:
    ssh = paramiko.SSHClient()
    ssh.set_missing_host_key_policy(paramiko.AutoAddPolicy())
    logger.info(f"🔗 Attempting SSH connection to {server}...")
    
    ssh.connect(hostname=server, username=username, password=password, timeout=TIMEOUT, allow_agent=False, look_for_keys=False)
    
    # Stabilize connection
    shell = ssh.invoke_shell()
    time.sleep(2)
    if shell.recv_ready():
        shell.recv(10000)
    shell.close()
    
    logger.info(f"✅ SSH connection established to {server}")
    return ssh

