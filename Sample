def is_java_not_found(output: str) -> bool:
    output_lower = output.lower()
    return any(phrase in output_lower for phrase in ["ksh: java: not found", "command not found", "bash: java:", "java: command not found"])

def parse_java_output(output: str) -> Dict:
    if not output or is_java_not_found(output):
        return {"Java Version": "Not Installed", "OpenJDK Runtime Environment": "Not Installed", "Vendor Details": "Not Installed"}

    lines = [line.strip() for line in output.splitlines() if line.strip()]
    version = lines[0].replace('"', '').strip() if lines else "Not Available"
    runtime_env = next((line for line in lines if "Runtime Environment" in line), "Not Available")
    vendor = next((line for line in lines if any(x in line for x in ["Server VM", "64-Bit", "OpenJDK", "Zulu", "Temurin"])), "Not Available")

    return {"Java Version": version, "OpenJDK Runtime Environment": runtime_env, "Vendor Details": vendor}

