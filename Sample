def is_python_not_found(output: str) -> bool:
    """Detects if Python is missing from the system path based on shell output."""
    output_lower = output.lower()
    return any(phrase in output_lower for phrase in [
        "python: command not found",
        "python3: command not found",
        "zsh: command not found: python",
        "ksh: python: not found",
        "bash: python:",
        "python is not recognized"  # Common on Windows CMD
    ])

def parse_python_output(output: str) -> str:
    lines = [line.strip() for line in output.splitlines() if line.strip()]
    
    version = "Not Available"
    
    if lines:
        first_line = lines[0].strip()
        # Python version is typically in format "Python 3.x.x"
        if "Python" in first_line:
            version = first_line
        else:
            version = first_line
    
    return version


def check_python312_installed(ssh: paramiko.SSHClient) -> str:
    """Check if Python 3.12 is installed by checking /usr/bin/python* listing"""
    try:
        _, stdout, stderr = ssh.exec_command("ls -ltrh /usr/bin/python*", timeout=10)
        output = stdout.read().decode('utf-8').strip()
        error_output = stderr.read().decode('utf-8').strip()
        
        # Check if command failed
        if error_output and "No such file or directory" in error_output:
            return "No"
        
        # Check if python3.12 is present in the listing
        if "python3.12" in output:
            return "Yes"
        else:
            return "No"
            
    except Exception:
        return "Error"


def check_python2_rpm_packages(ssh: paramiko.SSHClient) -> str:
    """Check if Python 2.7 related RPM packages are removed"""
    try:
        _, stdout, stderr = ssh.exec_command("rpm -qa | grep python2 | wc -l", timeout=10)
        output = stdout.read().decode('utf-8').strip()
        
        # Convert output to integer and check
        count = int(output) if output.isdigit() else -1
        
        if count == 0:
            return "Yes"
        elif count > 0:
            return "No"
        else:
            return "Error"
            
    except Exception:
        return "Error"


def check_python27_Executables_available(ssh: paramiko.SSHClient) -> str:
    """Check if Python 2.7 Executables are available under /usr/bin/python*"""
    try:
        _, stdout, stderr = ssh.exec_command("ls -ltrh /usr/bin/python* 2>/dev/null | grep -E 'python2\\.7|python2$' | wc -l", timeout=10)
        output = stdout.read().decode('utf-8').strip()
        error_output = stderr.read().decode('utf-8').strip()
        
        # Convert output to integer and check
        count = int(output) if output.isdigit() else -1
        
        if count > 0:
            # Get detailed information about Python 2.7 Executables
            _, detail_stdout, _ = ssh.exec_command("ls -ltrh /usr/bin/python* 2>/dev/null | grep -E 'python2\\.7|python2$'", timeout=10)
            detail_output = detail_stdout.read().decode('utf-8').strip()
            if detail_output:
                # Format the detailed output with executable names and details on separate lines
                executable_lines = detail_output.split('\n')
                formatted_details = []
                for line in executable_lines:
                    if line.strip():
                        formatted_details.append(line.strip())
                
                detailed_info = "\n".join(formatted_details)
                return f"Yes ({count} Executables found)\n\nPython 2.7 Executables Details:\n\n{detailed_info}"
            else:
                return f"Yes ({count} Executables found)"
        elif count == 0:
            return "No"
        else:
            return "Error"
            
    except Exception:
        return "Error"


def check_roster_automation_soft_link(ssh: paramiko.SSHClient) -> str:
