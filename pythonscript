def run_remote_cmd(ssh_client, command):
    # Use getpeername once; resolve hostname only if needed for logging
    ip_address = ssh_client.get_transport().getpeername()[0]
    try:
        # This looks up the hostname associated with the IP
        host = socket.gethostbyaddr(ip_address)[0]
    except (socket.herror, socket.gaierror):
        # Fallback to IP if DNS lookup fails
        host = ip_address
    print(f"\n[RUNNING ON Server {host}]: {command}")

    # Request a PTY to combine stdout/stderr and maintain order
    stdin, stdout, stderr = ssh_client.exec_command(command, get_pty=True)
    stdin.close() # Close stdin if you aren't sending interactive input

    full_output = []
    # readline() on a PTY-enabled channel is generally safe for real-time
    for line in iter(stdout.readline, ""):
        line_content = line.strip()
        if line_content:
            print(f"  {line_content}")
            full_output.append(line_content)

    # Capture the actual exit code from the remote process
    exit_status = stdout.channel.recv_exit_status()
    if exit_status != 0:
        print(f"  [ERROR]: Command failed with exit code {exit_status}")

    return "\n".join(full_output)

# 2. Excecute Commands through Service User Function Definition (Available to everything below)
def execute_service_commands(host, user, pwd, service_user, command):
    """Connects to host and runs commands as the specified service user."""
    client = paramiko.SSHClient()
    client.set_missing_host_key_policy(paramiko.AutoAddPolicy())
    
    try:
        client.connect(host, username=user, password=pwd, timeout=10)
        
        # Use [invoke_shell] for interactive sudo su - 
        shell = client.invoke_shell()

        # Clear initial banners
        time.sleep(2) 
        if shell.recv_ready():
            shell.recv(10000)

        # 1. Transition to the service user
        shell.send(f"sudo su - {service_user}\n")

        # Clear transition banners/prompts
        time.sleep(2) 
        if shell.recv_ready():
            shell.recv(10000)

        # Execute the specific Tomcat command
        shell.send(f"{command}\n")
        
        # Give the command time to execute and return output
        time.sleep(2) 
        
        output = ""
        if shell.recv_ready():
            # [recv]() returns available data in the buffer
            output = shell.recv(10000).decode('utf-8')
        
        return {command: output}

    except Exception as e:
        return {"Error": str(e)}
    finally:
        client.close()

def stopping_wait_for_webusernodeurl_status(url, jvm_name, timeout=30):
    """Verifying the WebUser Node JVMs & their URL status with a retry loop."""
    print(f"\n--- Checking {jvm_name} status and its Node URL {url} status ---")
    start_time = time.time()
    
    while time.time() - start_time < timeout:
        try:
            response = requests.get(url, timeout=10, verify=False)
            if response.status_code != 200:
                print(f"SUCCESS: {jvm_name} returned with Status Code as {response.status_code}, WebUser Node is down!")
                return True
        except requests.exceptions.RequestException:
            # Log failure but continue looping until timeout
            print(f"SUCCESS: {jvm_name} connection refused. It is down!")
        
        time.sleep(5)  # Wait between retries
    
    # Only returns False if the entire 'timeout' duration passes without a 200 OK
    print(f"[FAILURE]: {jvm_name} is still Up and Running, returning 200 OK after {timeout}s.")
    return False

