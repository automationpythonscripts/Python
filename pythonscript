def get_java_details(ssh, line):
    parts = line.split()
    if len(parts) < 8:
        return None
        
    # The 8th word is the java path (index 7)
    java_path = parts[7]
    classification = "Unknown"

    # 1. Classification Logic
    if "instana" in line.lower():
        classification = "Instana Agent"
    elif "ucd" in line.lower():
        classification = "UCD Agent"
    elif "/apps/tomcat9/kafka" in line.lower():
        classification = "Application Kafka Process"
    elif "srctmagc" in line.lower():
        classification = "Control M Job"
    elif "srcctmag" in line.lower():
        classification = "srcctmag"
    elif "pdt" in line.lower():
        ws_parts = line.split()
        if ws_parts:
            name = ws_parts[-1]
            classification = name.replace("--spring.config.location=file:/cloverleaf/", "").replace("/application.properties", "")
    elif "bdd" in line.lower():
        ws_parts = line.split()
        if ws_parts:
            name = ws_parts[-1]
            classification = name.replace("--spring.config.location=file:/cloverleaf/", "").replace("/application.properties", "")
    elif "prod_sps_mdm" in line.lower():
        ws_parts = line.split()
        if len(ws_parts) >= 4:
            info = " ".join(ws_parts[-4:])
            classification = info.replace("/usr/WebSphere/AppServer/profiles/", "").replace("/config", "")
    elif "-Didentification.nodeid=" in line:
        match = re.search(r'-Didentification\.nodeid=(\S+)', line)
        classification = match.group(1) if match else "N/A"
    elif "fbda" in line.lower():
        classification = "FBDA"
    elif "pds" in line.lower():
        ws_parts = line.split()
        if ws_parts:
            # Get the last item ($NF) and then the last word after the final slash
            classification = ws_parts[-1].split('/')[-1]
    elif "/wsapps/cores/" in line:
        match = re.search(r'/wsapps/cores/([^/\s]+)', line)
        classification = match.group(1) if match else "N/A"

    # 2. Get Java Version Info
    # Note: java -version and shell errors (like Permission Denied) output to STDERR
    cmd = f"{java_path} -version"
    stdin, stdout, stderr = ssh.exec_command(cmd)
    
    # Read both streams to ensure no diagnostic messages are missed
    err_output = stderr.read().decode().strip()
    out_output = stdout.read().decode().strip()
    combined_output = (err_output + out_output).lower()
    
    # 3. Handle Permission Denied
    if "permission denied" in combined_output:
        return {
            "Process Type": classification,
            "Path": java_path,
            "Java Version": "Permission Denied",
            "Runtime": "Permission Denied",
            "Vendor Details": "Permission Denied"
        }
    
    # 4. Robust Regex Parsing
    v_match = re.search(r'version "([^"]+)"', combined_output)
    java_ver = v_match.group(1) if v_match else "N/A"
    
    r_match = re.search(r'runtime environment ([^\n]+)', combined_output)
    runtime = r_match.group(1).strip() if r_match else "N/A"
    
    vm_match = re.search(r'(?:vm|server) ([^\n]+)', combined_output)
    vendor = vm_match.group(1).strip() if vm_match else "N/A"
    
    return {
        "Process Type": classification,
        "Path": java_path,
        "Java Version": java_ver.upper() if java_ver != "N/A" else java_ver,
        "Runtime": runtime,
        "Vendor Details": vendor
    }

try:
    ssh = paramiko.SSHClient()
    ssh.set_missing_host_key_policy(paramiko.AutoAddPolicy())
    ssh.connect(hostname, username=username, password=password, timeout=15)

    # Use [b] to avoid catching the grep process itself
    ps_cmd = "ps -ef | grep '[b]in/java'"
    stdin, stdout, stderr = ssh.exec_command(ps_cmd)
    ps_output = stdout.read().decode().strip()

    results = []
    if ps_output:
        for line in ps_output.split('\n'):
            details = get_java_details(ssh, line)
            if details:
                results.append(details)

    if results:
        print(tabulate(results, headers="keys", tablefmt="grid"))
    else:
        print("No Java processes found.")

    ssh.close()

except Exception as e:
    print(f"Error occurred: {e}")
