def check_url(task):
    code, status_msg, is_up = get_status(task['URL'], task['Timeout'])
    return {
        'Env Type': task['Env Type'],
        'F5 and Node Names': task['F5 and Node Names'],
        'URL': task['URL'],
        'StatusCode': code,
        'URLStatus': status_msg,
        'IsUP': is_up
    }


