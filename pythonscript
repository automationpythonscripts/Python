# 1. Helper function to strip ANSI color codes
def strip_ansi_codes(text):
    """Removes ANSI escape sequences (colors, formatting) from a string."""
    ansi_escape = re.compile(r'\x1B(?:[@-Z\\-_]|\[[0-?]*[ -/]*[@-~])')
    return ansi_escape.sub('', text)

