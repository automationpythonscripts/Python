def get_status(task):
    """Checks the URL and returns a dictionary with metadata"""
    # Unpack the tuple (env_name, url) passed from executor
    env_name, url = task 

    try:
        # Use a timeout and disable SSL verification as requested
        response = requests.get(url, timeout=10, verify=False)
        status_code = response.status_code
        content = response.text
        
        if status_code == 200:
            # Inline style for GREEN color and center alignment
            status_msg = (
                '<div style="color: green; font-weight: bold;">'
                'UP and Running'
                '</div>'
            )
        elif status_code == 404:
            # Check if the environment belongs to NodeURL or F5
            if env_name in environments_NodeURL:
                # Inline style for RED color and center alignment
                # Use <br> for HTML email line breaks
                status_msg = (
                    f'<div style="color: green; font-weight: bold;">JVM UP</div>'
		    f'<div style="color: red; font-weight: bold;">'
                    f'but URL was DOWN<br>Context Root Not Found'
                    f'</div>'
                )
            elif env_name in environments_F5:
                # Inline style for RED color and center alignment
                # Use <br> for HTML email line breaks
                status_msg = (
		    f'<div style="color: red; font-weight: bold;">'
                    f'URL was DOWN<br>Context Root Not Found'
                    f'</div>'
                )           
        else:
            # Inline style for RED color and center alignment
            # Use <br> for HTML email line breaks
            status_msg = (
                f'<div style="color: red;">'
                f'DOWN ({status_code})<br>Service Unavailable'
                f'</div>'
            )
    except requests.exceptions.ConnectionError:
        # Inline style for RED color and center alignment
        # Use <br> for HTML email line breaks
        status_code, status_msg = "FAILED", '<div style="color: red;">This site can’t be reached<br>URL Refused to connect</div>'
    except requests.exceptions.Timeout:
        # Inline style for Orange color and center alignment
        status_code, status_msg = "TIMEOUT", '<div style="color: orange;">Server Timeout</div>'
    except Exception as e:
        # Inline style for RED color and center alignment
        status_code, status_msg = "ERROR", f'<div style="color: red;">{str(e)}</div>'

    # Helper to wrap text in a centering div for the final return
    center = lambda x: f'<div style="text-align: center;">{x}</div>'

    return {
        'Non-Prod Env URL': env_name,
        'F5 and Node URLs Info': url,
        'StatusCode': center(status_code),
        'URLStatus': center(status_msg)  # Already wrapped in its own styled div
    }
    
def send_outlook_mail(results, duration_str, end_et):
    """Sends the formatted results via Outlook Desktop App"""
    print("\nDrafting Outlook email...")
    now = datetime.now()
    hour = now.hour
    shift = "S1" if 6 <= hour < 15 else "S2" if 15 <= hour < 23 else "S3"
    date_today = now.strftime("%d %B %Y")

    outlook = win32.Dispatch('outlook.application')
    mail = outlook.CreateItem(0)
    mail.To = 'Venkatesh.Sure@carelon.com' # Update with actual recipient
    mail.CC = 'Venkatesh.Sure@carelon.com'
    mail.Subject = f'[SPS Monitoring Report] - Non-PROD WBS Env URLs Report - {shift} - {date_today}'
    # Building the HTML Table for the email body
    table_rows = ""
    for res in results:
        color = "green" if res['URLStatus'] == "UP and Running" else "red"
        table_rows += f"""
        <tr>
            <!-- Added fixed width and restricted wrapping to the first column -->
            <td style="border:1px solid #ddd; padding:8px; width: 500px; white-space: nowrap;">{res['Non-Prod Env URL']}</td>
            <td style="border:1px solid #ddd; padding:8px;">{res['F5 and Node URLs Info']}</td>
            <td style="border:1px solid #ddd; padding:8px;">{res['StatusCode']}</td>
            <td style="border:1px solid #ddd; padding:8px; color:{color}; font-weight:bold;">{res['URLStatus']}</td>
        </tr>"""

    mail.HTMLBody = f"""
    <html>
    <body>
            <p>Hi Team,</p>
            <p>Please find the below Non-Production WBS URL's Health Check report.</p>
	    <p>Non-Prod WBS Env URL's Checking Started at <i>{start_et.strftime(fmt)}</i>.</p>
    <!-- Note: table-layout: fixed helps enforce specific column widths -->        
    <table style="border-collapse: collapse; width: 200%; font-family: Arial, sans-serif; table-layout: auto;">
            <tr style="background-color: #f2f2f2;">
                <!-- Apply the width to the Header as well --> 
                <th style="border:1px solid #ddd; padding:8px; text-align:left; width: 500px;">Non-Prod Env URL</th>
                <th style="border:1px solid #ddd; padding:8px; text-align:left;">URLs Info</th>
                <th style="border:1px solid #ddd; padding:8px; text-align:center;">Status Code</th>
                <th style="border:1px solid #ddd; padding:8px; text-align:center;">URL Health Status</th>
            </tr>
            {table_rows}
        </table>
        <p>
           Non-Prod WBS Env URL's Checking Finished at <i>{end_et.strftime(fmt)}</i>.<br>
           Non-Prod WBS Env URL's Status Health Check Verified within <i>{duration_str}.</i>
        </p>
        <p><i>This is an automated report.</i></p>
        <p>Regards,<br>Venkatesh Sure</p>
    </body>
    </html>
    """
    mail.Send()
    print("Email sent successfully via Outlook.")

