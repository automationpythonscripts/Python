AGENT_URL = os.getenv("AGENT_URL", "http://10.22.147.198:18081/").rstrip("/")
SOURCE_API_KEY = os.getenv("CYBERARK_API_KEY")
PRIVATE_KEY_PATH = os.getenv("PRIVATE_KEY_PATH", "/local_home/an453200ad/private_key.pem")  # Keep this secure!

# Load private key once
with open(PRIVATE_KEY_PATH, "rb") as f:
    private_key = serialization.load_pem_private_key(f.read(), password=None)

class AgentResponse(BaseModel):
    appid: str
    safe: str
    object_name: str
    encrypted_password: str

def hybrid_decrypt(encrypted_b64: str) -> str:
    """Decrypt hybrid RSA+AES data"""
    combined = base64.b64decode(encrypted_b64)

    # Split: RSA encrypted AES key (256 bytes for 2048-bit) + nonce (12) + ciphertext
    rsa_size = 256  # Adjust if using 4096-bit (512)
    encrypted_aes_key = combined[:rsa_size]
    nonce = combined[rsa_size:rsa_size+12]
    ciphertext = combined[rsa_size+12:]

    # Decrypt AES key with private key
    aes_key = private_key.decrypt(
        encrypted_aes_key,
        padding.OAEP(
            mgf=padding.MGF1(algorithm=hashes.SHA256()),
            algorithm=hashes.SHA256(),
            label=None
        )
    )

    # Decrypt password with AES-GCM
    aesgcm = AESGCM(aes_key)
    plaintext = aesgcm.decrypt(nonce, ciphertext, None)
    return plaintext.decode("utf-8")

def fetch_password_from_agent(appid: str, safe: str, object_name: str) -> Dict:
    url = f"{AGENT_URL}/password"
    headers = {"X-API-Key": SOURCE_API_KEY, "Accept": "application/json"}
    params = {"appid": appid, "safe": safe, "object_name": object_name, "x": str(int(time.time()))} # Sending current timestamp as 'x'
    response = requests.get(url, headers=headers, params=params, timeout=15)
    if response.status_code == 422:
        print(f"Validation Error Details: {response.json()}")  # Crucial for debugging
    response.raise_for_status()
    data = response.json()
    validated = AgentResponse(**data)
    plain_password = hybrid_decrypt(validated.encrypted_password)

    return {
        "appid": validated.appid,
        "safe": validated.safe,
        "object_name": validated.object_name,
        "decrypted_password": plain_password
    }

# Usage
