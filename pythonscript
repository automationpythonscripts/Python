def get_java_version(ssh: paramiko.SSHClient, command: str) -> str:
    try:
        # Using -version usually outputs to stderr
        _, stdout, stderr = ssh.exec_command(f"{command} -version", timeout=10)
        output = stderr.read().decode('utf-8').strip() or stdout.read().decode('utf-8').strip()
        
        if not output:
            return "NA" if command == ORACLE_JDK_PATH else "Not Available"
        
        return output.splitlines()[0].replace('"', '').strip()
    except Exception:
        return "NA" if command == ORACLE_JDK_PATH else "Error"

def check_server(server: str, app_name: str, index: int) -> Dict:
    row = {
        "Index": index, # Used for sorting back to original order
        "Application": app_name,
        "Server": server,
        "System Java/JRE": "Pending",
        "Application Java Version": "Pending"
    }
    try:
        """Connects to host and runs commands as the specified user."""
        ssh = paramiko.SSHClient()
        ssh.set_missing_host_key_policy(paramiko.AutoAddPolicy())
        ssh.connect(
            hostname=server, username=SSH_USER, password=SSH_PASS,
            timeout=TIMEOUT, allow_agent=False, look_for_keys=False
        )
        shell = ssh.invoke_shell()

        # Clear initial banners
        time.sleep(2) 
        if shell.recv_ready():
            shell.recv(10000)
        
        row["System Java/JRE"] = get_java_version(ssh, "java")
        row["Application Java Version"] = get_java_version(ssh, ORACLE_JDK_PATH)
        ssh.close()
        logger.info(f"✅ {server} audited.")
    except Exception as e:
        row["System Java/JRE"] = "Connection Failed"
        row["Application Java Version"] = "Connection Failed"
        logger.error(f"❌ {server} failed: {str(e)[:50]}")
    
    return row

def create_html_report(data: List[Dict]) -> str:
    html = """
    <table border="1" style="border-collapse: collapse; width:100%; font-family: Calibri, sans-serif;">
        <thead>
            <tr style="background-color: #2E7D32; color: white;">
                <th style="padding:10px;">Application</th>
                <th style="padding:10px;">Server</th>
                <th style="padding:10px;">System Java/JRE</th>
                <th style="padding:10px;">Application Java Version</th>
            </tr>
        </thead>
        <tbody>
    """
    
    # Logic to handle row merging for Applications
    df = pd.DataFrame(data)
    app_counts = df['Application'].value_counts(sort=False)
    
    current_app = ""
    for _, row in df.iterrows():
        oracle_val = str(row["Application Java Version"])
        # Coloring logic
        bg_color = "#ffffff"
        if "19." in oracle_val: bg_color = "#d4edda"
        elif oracle_val == "NA": bg_color = "#f8f9fa"
        elif "Failed" in oracle_val: bg_color = "#f8d7da"

        html += "<tr>"
        if row['Application'] != current_app:
            count = app_counts[row['Application']]
            html += f'<td rowspan="{count}" style="background-color: #E8F5E9; font-weight: bold; text-align: center; border: 1px solid #2E7D32;">{row["Application"]}</td>'
            current_app = row['Application']
        
        html += f'<td style="padding:5px; border: 1px solid #bbb;">{row["Server"]}</td>'
        html += f'<td style="padding:5px; border: 1px solid #bbb;">{row["System Java/JRE"]}</td>'
        html += f'<td style="padding:5px; border: 1px solid #bbb; background-color: {bg_color};">{oracle_val}</td>'
        html += "</tr>"
    
    html += "</tbody></table>"
    return html

