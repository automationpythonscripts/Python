# 2. Worker function for the thread
def check_url(task):
    env_name, url, timeout_val = task
    code, status = get_status(url, timeout_val)
    return {
        'Non-Prod Env': env_name, 
        'F5 and Node URLs': url, 
        'StatusCode': code, 
        'URLStatus': status
    }

# 3. Run Parallel Checks
# Use ThreadPoolExecutor for I/O-bound URL checking and to Execute in parallel with RETRIEVE in order
with ThreadPoolExecutor(max_workers=25) as executor:
    # executor.map preserves the order of the input 'tasks'
    unordered_results = list(executor.map(check_url, tasks))

