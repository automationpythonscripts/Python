def get_category_and_env(env_name):
    categories = [
        "PEGA", "SPS Core Service", "PARES Core Service", "UIX Core Service", "OEM",
        "Roster Automation", "Prov360", "PKM", "SPS ProvRestore", "UIX",
        "SPS Audit History", "NETWORKAIprov360", "Provider360", "MATCH SERVER",
        "PARESOld", "SPSDARTUI"
    ]
    categories.sort(key=len, reverse=True)

    for cat in categories:
        if env_name.startswith(cat):
            remaining = env_name.replace(cat, "", 1).strip()
            return cat, remaining if remaining else "General"
    return "Other", env_name


def get_status(url, custom_timeout=10):
    headers = {
        "User-Agent": "Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 "
                      "(KHTML, like Gecko) Chrome/122.0.0.0 Safari/537.36 Edg/122.0.0.0",
        "Accept-Language": "en-US,en;q=0.9",
        "Cache-Control": "no-cache",
        "Pragma": "no-cache"
    }

    try:
        with requests.Session() as session:
            response = session.get(url, headers=headers, timeout=custom_timeout,
                                   allow_redirects=True, verify=False)
            status_code = response.status_code
            style_base = "font-weight: bold; text-align: center;"

            if status_code == 200:
                status_msg = f'<div style="color: green; {style_base}">UP and Running</div>'
                is_up = True
            elif status_code == 404:
                if any(x in url.upper() for x in ["WELLPOINT", "DC04", "VA10"]):
                    status_msg = ('<div style="color: green; font-weight: bold; text-align:center;">JVM UP</div>'
                                  '<div style="color: red; font-weight: bold; text-align:center;">'
                                  'but URL was DOWN<br>Context Root Not Found</div>')
                else:
                    status_msg = ('<div style="color: red; font-weight: bold; text-align:center;">'
                                  'URL was DOWN<br>Context Root Not Found</div>')
                is_up = False
            elif status_code in [500, 403, 503]:
                status_msg = f'<div style="color: red; {style_base}">DOWN ({status_code})<br>Service Unavailable</div>'
                is_up = False
            else:
                status_msg = f'<div style="color: orange; {style_base}">Status: {status_code}</div>'
                is_up = False

            return status_code, status_msg, is_up

    except requests.exceptions.ConnectionError:
        return "FAILED", "This site can’t be reached<br>URL Refused to connect", False
    except requests.exceptions.Timeout:
        return "TIMEOUT", "Server Timeout", False
    except Exception as e:
        return "ERROR", str(e), False


