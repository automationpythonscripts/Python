def clean_env_name(env_name):
    # Comprehensive list of words/phrases to remove (sorted by length descending for better matching)
    if not env_name:
        return env_name    
    cleaned_name = env_name.strip()

    words_to_remove = {
        'NON-PROD PEGA DEV1', 'NON-PROD PEGA DEV2', 'NON-PROD PEGA DEV3', 'NON-PROD PEGA DEV4', 'NON-PROD PEGA DEV5', 'NON-PROD PEGA DEV6', 'NON-PROD PEGA DEV7',
        'NON-PROD PEGA SBX1', 'NON-PROD PEGA SBX2', 'NON-PROD PEGA SBX3', 'NON-PROD PEGA SBX4', 'NON-PROD PEGA SBX5', 'NON-PROD PEGA SBX6', 'NON-PROD PEGA SBX7',
        'NON-PROD PEGA SIT1', 'NON-PROD PEGA SIT2', 'NON-PROD PEGA SIT3', 'NON-PROD PEGA SIT4', 'NON-PROD PEGA SIT5', 'NON-PROD PEGA SIT6', 'NON-PROD PEGA SIT7',
        'NON-PROD PEGA UAT1', 'NON-PROD PEGA UAT2', 'NON-PROD PEGA UAT3', 'NON-PROD PEGA UAT4', 'NON-PROD PEGA UAT5', 'NON-PROD PEGA UAT6', 'NON-PROD PEGA UAT7',
        'NON-PROD PEGA PERF1 LOADBALANCER', 'NON-PROD PEGA PERF1 HAZELCAST', 'NON-PROD PEGA PERF1', 'NON-PROD PEGA PERF1 PDM', 'NON-PROD PEGA PERF1 WEBUSER', 
        'NON-PROD PEGA PERF2 LOADBALANCER', 'NON-PROD PEGA PERF1 HAZELCAST', 'NON-PROD PEGA PERF2', 'NON-PROD PEGA PERF2 PDM', 'NON-PROD PEGA PERF2 WEBUSER'
    }
    
    # Remove category words using regex for better word boundary matching
    for word in words_to_remove:
        # Create pattern that matches the word with optional word boundaries
        pattern = re.compile(re.escape(word), re.IGNORECASE)
        cleaned_name = pattern.sub('', cleaned_name)
    
    # Clean up multiple spaces, tabs, and newlines
    cleaned_name = re.sub(r'\s+', ' ', cleaned_name)
    
    # Remove leading/trailing spaces and common separators
    cleaned_name = cleaned_name.strip(' -_.,;:')
    
    # Handle edge cases where cleaning results in empty or very short strings
    if not cleaned_name or len(cleaned_name.strip()) < 2:
        return env_name
    
    return cleaned_name

