        mail.HTMLBody = f"""
        <html><body>
            <p>Hi Team,</p>
            <p>Please find the Java version verification report below:</p>
            {create_html_report(data)}
            <p>Regards,<br><b>Sure Venkatesh</b></p>
        </body></html>"""
        mail.Send()
        logger.info("📧 Email sent successfully.")
    except Exception as e:
        logger.error(f"Failed to send email: {e}")

