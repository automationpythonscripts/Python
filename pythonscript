from fastapi import FastAPI, HTTPException, Query, Depends, Security
from fastapi.security import APIKeyHeader
from fastapi.middleware.cors import CORSMiddleware
import subprocess
import os
from typing import Optional
from cryptography.fernet import Fernet
import base64
from dotenv import load_dotenv
 
# Load environment variables from .env file
load_dotenv()
 
app = FastAPI()
 
# Add CORS middleware
app.add_middleware(
    CORSMiddleware,
    allow_origins=["*"],  # Restrict to specific domains in production
    allow_credentials=True,
    allow_methods=["*"],
    allow_headers=["*"],
)
 
# CyberArk CLI path
CLI_PATH = "/opt/CARKaim/sdk/clipasswordsdk"
 
# API Key configuration
API_KEY_NAME = "X-API-Key"
API_KEY = os.getenv("CYBERARK_API_KEY")
if not API_KEY:
    raise ValueError("CYBERARK_API_KEY environment variable is required")
api_key_header = APIKeyHeader(name=API_KEY_NAME, auto_error=True)
 
# Encryption configuration
ENCRYPTION_KEY = os.getenv("ENCRYPTION_KEY")
if not ENCRYPTION_KEY:
    raise ValueError("ENCRYPTION_KEY environment variable is required")
# Ensure the key is 32 bytes for Fernet
if len(ENCRYPTION_KEY.encode()) != 32:
    # Pad or truncate to 32 bytes
    key_bytes = ENCRYPTION_KEY.encode()[:32].ljust(32, b'0')
else:
    key_bytes = ENCRYPTION_KEY.encode()
 
print(f"Using encryption key (first 10 chars): {ENCRYPTION_KEY[:10]}...")  # Debug log
print(f"Key length: {len(key_bytes)} bytes")  # Debug log
 
# Convert to Fernet compatible key
fernet_key = base64.urlsafe_b64encode(key_bytes)
cipher = Fernet(fernet_key)
 
 
def get_cipher_from_key(decryption_key: str) -> Fernet:
    """Create a Fernet cipher from a decryption key"""
    # Ensure the key is 32 bytes for Fernet
    if len(decryption_key.encode()) != 32:
        # Pad or truncate to 32 bytes
        key_bytes = decryption_key.encode()[:32].ljust(32, b'0')
    else:
        key_bytes = decryption_key.encode()
   
    # Convert to Fernet compatible key
    fernet_key = base64.urlsafe_b64encode(key_bytes)
    return Fernet(fernet_key)
 
 
def encrypt_password(password: str) -> str:
    """Encrypt a password using Fernet symmetric encryption"""
    encrypted_password = cipher.encrypt(password.encode())
    return base64.urlsafe_b64encode(encrypted_password).decode()
 
 
def decrypt_password(encrypted_password: str) -> str:
    """Decrypt a password using Fernet symmetric encryption"""
    try:
        print(f"Attempting to decrypt: {encrypted_password[:50]}...")  # Debug log
        encrypted_bytes = base64.urlsafe_b64decode(encrypted_password.encode())
        decrypted_password = cipher.decrypt(encrypted_bytes)
        return decrypted_password.decode()
    except Exception as e:
        print(f"Decryption error: {str(e)}")  # Debug log
        raise HTTPException(
            status_code=400,
            detail=f"Failed to decrypt password: {str(e)}"
        )
 
 
async def get_api_key(api_key: str = Security(api_key_header)):
    """
    Validate API key from request header
    """
    if api_key != API_KEY:
        raise HTTPException(
            status_code=403,
            detail="Invalid or missing API Key"
        )
    return api_key
 
 
@app.get("/password")
def get_password(
    api_key: str = Depends(get_api_key),
    appid: str = Query(..., description="Application ID"),
    safe: str = Query(..., description="Safe name"),
    object_name: str = Query(..., description="Object name"),
):
    """
    Retrieve password from CyberArk CLI (API Key authentication required)
   
    Headers:
        X-API-Key: Your API key for authentication
    """
 
    query = f"Safe={safe};Folder=Root;Object={object_name}"
 
    try:
        password_cmd = [
            CLI_PATH,
            "GetPassword",
            "-p", f"AppDescs.AppID={appid}",
            "-p", f"Query={query}",
            "-o", "Password"
        ]
 
        password_output = subprocess.check_output(
            password_cmd,
            universal_newlines=True
        ).strip()
 
        # Encrypt the password before returning
        encrypted_password = encrypt_password(password_output)
 
        return {
            "appid": appid,
            "safe": safe,
            "object_name": object_name,
            "encrypted_password": encrypted_password
        }
 
    except subprocess.CalledProcessError as e:
        raise HTTPException(
            status_code=500,
            detail=f"Error executing CLI command: {str(e)}"
        )
 
    except FileNotFoundError:
        raise HTTPException(
            status_code=500,
            detail=f"CyberArk CLI not found at {CLI_PATH}"
        )
 
 
@app.post("/decrypt")
def decrypt_endpoint(
    api_key: str = Depends(get_api_key),
    encrypted_password: str = Query(..., description="Encrypted password to decrypt"),
    decryption_key: str = Query(..., description="Decryption key (32 characters)")
):
    """
    Decrypt an encrypted password (API Key authentication required)
   
    Headers:
        X-API-Key: Your API key for authentication
   
    Parameters:
        encrypted_password: The encrypted password to decrypt
        decryption_key: The 32-character key used for decryption
    """
   
    try:
        # Create cipher from the provided decryption key
        decrypt_cipher = get_cipher_from_key(decryption_key)
       
        print(f"Attempting to decrypt with key: {decryption_key[:10]}...")  # Debug log
        print(f"Encrypted password: {encrypted_password[:50]}...")  # Debug log
       
        encrypted_bytes = base64.urlsafe_b64decode(encrypted_password.encode())
        decrypted_password = decrypt_cipher.decrypt(encrypted_bytes)
       
        return {
            "decrypted_password": decrypted_password.decode()
        }
    except Exception as e:
        print(f"Decryption error: {str(e)}")  # Debug log
        raise HTTPException(
            status_code=400,
            detail=f"Decryption failed: {str(e)}"
        )
