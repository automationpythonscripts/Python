# ================== ASYNC SCREENSHOT FUNCTION ==================
async def capture_screenshot(browser, url, name, output_dir="screenshots"):
    """Captures a single screenshot with isolated browser context."""
    if not os.path.exists(output_dir):
        os.makedirs(output_dir)
    
    # Create a new context for better isolation
    context = await browser.new_context(
        viewport={'width': 1200, 'height': 920},
        ignore_https_errors=True,
        user_agent="Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36"
    )
    
    page = await context.new_page()
    output_path = os.path.abspath(os.path.join(output_dir, f"{name}.png"))
    
    try:
        print(f"Capturing screenshot: {url}")
        await page.goto(url, wait_until="networkidle", timeout=60000)
        await page.screenshot(path=output_path, full_page=True)
        return output_path
    except Exception as e:
        print(f"Error capturing {url}: {e}")
        return None
    finally:
        await context.close()  # Close the entire context, not just the page

async def monitor_all(data_list):
    """Orchestrates concurrent screenshot captures."""
    async with async_playwright() as p:
        browser = await p.chromium.launch()
        tasks = [capture_screenshot(browser, item['url'], item['name']) for item in data_list]
        file_paths = await asyncio.gather(*tasks)
        await browser.close()
        return [f for f in file_paths if f]

# ================== URL STATUS CHECK ==================
def get_status(url, custom_timeout=10):
    """
    Checks URL status mimicking Microsoft Edge InPrivate mode.
    """
    url = url.strip()
    
    # 1. Default Headers
    headers = {
        "User-Agent": "Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/122.0.0.0 Safari/537.36 Edg/122.0.0.0",
        "Accept-Language": "en-US,en;q=0.9",
        "Cache-Control": "no-cache",
        "Pragma": "no-cache"
    }

    # 2. Specific Headers for Pares Core Services F5 URL
    target_url = "https://paresspsservices.anthem.com/spsservices"
    if url == target_url:
    # Comprehensive Incognito-style headers
        headers.update({
            "User-Agent": "Mozilla/149.0.2 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/147.0.7727.56 Safari/537.36 Edg/147.0.3912.60",
            "Accept-Language": "en-US,en;q=0.9",
            "Cache-Control": "no-cache",
            "Pragma": "no-cache",
            "Sec-Ch-Ua": '"Microsoft Edge";v="146", "Chromium";v="147", "Not?A_Brand";v="99"',
            "Sec-Ch-Ua-Mobile": "?0",
            "Sec-Ch-Ua-Platform": '"Windows"',
            "Sec-Fetch-Dest": "document",
            "Sec-Fetch-Mode": "navigate",
            "Sec-Fetch-Site": "none"
        })

    try:
        # Use a fresh session with no cookies to simulate Incognito
        session = requests.Session()
        session.cookies.clear() 

        # No-verify and fresh session mimics InPrivate behavior
        with requests.Session() as session:
            response = session.get(
                url, 
                headers=headers, 
                timeout=custom_timeout, 
                allow_redirects=True, 
                verify=False
            )
            status_code = response.status_code
            style_base = "font-weight: bold; text-align: center;"

            if status_code == 200:
                status_msg = f'<div style="color: green; {style_base}">UP and Running</div>'
            
            elif status_code == 404:
                if any(x in url.upper() for x in ["WELLPOINT", "DC04", "VA10"]):
                    status_msg = (
                        '<div style="color: green; font-weight: bold; text-align:center;">JVM UP</div>'
                        '<div style="color: red; font-weight: bold; text-align:center;">'
                        'but URL was DOWN<br>Context Root Not Found'
                        '</div>'
                    )
                else:
                    status_msg = (
                        '<div style="color: red; font-weight: bold; text-align:center;">'
                        'URL was DOWN<br>Context Root Not Found'
                        '</div>'
                    )
            
            elif status_code in [500, 403, 503]:
                status_msg = (
                    f'<div style="color: red; {style_base}">'
                    f'DOWN ({status_code})<br>Service Unavailable'
                    f'</div>'
                )           
            
            else:
                status_msg = f'<div style="color: orange; {style_base}">Status: {status_code}</div>'
            
            return status_code, status_msg

    except requests.exceptions.ConnectionError:
        return "FAILED", '<div style="text-align: center;">This site can’t be reached<br>URL Refused to connect</div>'
    except requests.exceptions.Timeout:
        return "TIMEOUT", '<div style="text-align: center;">Server Timeout</div>'
    except Exception as e:
        return "ERROR", str(e)

# ================== CATEGORY & CLEANING FUNCTIONS ==================
def get_category(env_name):
    """Categorize environment names into predefined categories with comprehensive keyword mapping"""
    if not env_name or not isinstance(env_name, str):
        return 'OTHER'
    
    env_upper = env_name.upper().strip()
    
    # Define comprehensive category mappings with merged common words
    category_keywords = {
        'PEGA': ['PEGA', 'HAZELCAST', 'STREAM', 'SEARCH', 'BACKGROUND', 'BIX', 'AGENT', 'PDM', 'WEBUSER'],
        'SPS CORE SERVICES': ['SPS CORE SERVICE'],
        'PARES CORE SERVICES': ['PARES CORE SERVICE'],
        'UIX CORE SERVICE': ['UIX CORE SERVICE'],
        'PROVIDER360 PDS SERVICES': ['PROVIDER360', 'PDS'],
        'PROVNEXUS SERVICES': ['PROVNEXUS', 'PROVNEXUS SERVICES'],
        'ROSTER AUTOMATION': ['ROSTER AUTOMATION'],
        'SPSDARTUI': ['SPSDARTUI'],
        'PKM': ['PKM'],
        'MATCH SERVER': ['MATCH SERVER'],
        'NETWORKAI': ['NETWORKAI'],
        'OEM': ['OEM', 'CONSOLE LOGIN'],
        'PDT': ['PDT'],
        'BPD': ['BPD'],
        'UIX': ['UIX'],
        'F5 PORTAL': ['F5 Portal', 'VIP',],
        'APPVIEWX': ['APPVIEWX'],
        'PARESOLD': ['PARESOLD'],
        'PROV360SERVICES': ['PROV360SERVICES'],
        'SPSPROVRESTORE': ['SPSPROVRESTORE'],
        'SPSAUDITHISTORY': ['SPSAUDITHISTORY']
    }
  
    # Check each category for matching keywords (prioritize longer matches first)
    for category, keywords in category_keywords.items():
        # Sort keywords by length (descending) to match longer phrases first
        sorted_keywords = sorted(keywords, key=len, reverse=True)
        for keyword in sorted_keywords:
            if keyword in env_upper:
                return category
    
    return 'OTHER'

def clean_env_name(env_name):
    """Remove category-related words from environment names with improved text processing"""
    if not env_name or not isinstance(env_name, str):
        return env_name
    
    # Comprehensive list of words/phrases to remove (sorted by length descending for better matching)
    words_to_remove = [
        'SPS CORE SERVICE', 'PARES CORE SERVICE', 'UIX CORE SERVICE', 'ROSTER AUTOMATION',
        'MATCH SERVER', 'F5 Portal', 'PDT', 'BPD', 'PROVIDER360 PDS Services', 'PROVNEXUS Services', 'UIX', 'SPSProvRestore', 'SPSAuditHistory',
        'NETWORKAI', 'APPVIEWX', 'PARESOld', 'SPSDARTUI', 'PEGA', 'PKM', 'OEM', 'Prov360Services'
    ]
    
    cleaned_name = env_name
    
    # Remove category words using regex for better word boundary matching
    for word in words_to_remove:
        # Create pattern that matches the word with optional word boundaries
        pattern = re.compile(re.escape(word), re.IGNORECASE)
        cleaned_name = pattern.sub('', cleaned_name)
    
    # Clean up multiple spaces, tabs, and newlines
    cleaned_name = re.sub(r'\s+', ' ', cleaned_name)
    
    # Remove leading/trailing spaces and common separators
    cleaned_name = cleaned_name.strip(' -_.,;:')
    
    # Handle edge cases where cleaning results in empty or very short strings
    if not cleaned_name or len(cleaned_name.strip()) < 2:
        return env_name
    
    return cleaned_name

