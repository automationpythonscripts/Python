# 2. Iterate through each dictionary independently to avoid overwriting data
datasets = [
    ("F5", environments_F5_Appwise),
    ("Node", environments_NodeURL_Appwise)
]

# 2. Build tasks in specific order based on env_keys as Environment F5 -> Environment Node along with App wise SPSCORESERVICES/WBS -> PKM -> MATCH
for key in env_keys:
    for type_name, data in datasets:
        for group_name, subgroups in data.items():
            for sub_name, labels in subgroups.items():
                for label, urls in labels.items():
                    # Check if the environment key matches the label
                    if key.upper() in label.upper():
                        for url in urls:
                            if url not in seen_urls:
                                all_tasks.append({
                                    'type': type_name,
                                    'group': group_name, 
                                    'sub': sub_name, 
                                    'label': label, 
                                    'url': url
                                })
                                seen_urls.add(url)

print(f"🚀 Checking {len(all_tasks)} URLs in parallel...")

# 3. Use executor.map to maintain the sorted order of all_tasks
results_bucket = {}

# 4. Execute and Print using ThreadPoolExecutor for I/O-bound URL checking and to Execute in parallel with RETRIEVE in order based on Env Wise
with ThreadPoolExecutor(max_workers=30) as executor:
    # Pass the label and url to get_status for each task in all_tasks
    # We use a lambda or list comprehension to prepare the arguments
    results = list(executor.map(lambda t: get_status(t['label'], t['url']), all_tasks))

# 5. Populate the bucket using the ordered results
for task, res in zip(all_tasks, results):
    g, s = task['group'], task['sub']
    
    if g not in results_bucket: 
        results_bucket[g] = {}
    if s not in results_bucket[g]: 
        results_bucket[g][s] = []
        
    results_bucket[g][s].append(res)

