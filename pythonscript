class EmailLogger(object):
    def __init__(self):
        self.terminal = sys.stdout
        self.log = io.StringIO()

    def write(self, message):
        self.terminal.write(message)
        self.log.write(message)

    def flush(self):
        self.terminal.flush()

    def get_log(self):
        return self.log.getvalue()

