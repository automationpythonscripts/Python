# 1. Merge dictionaries safely (Python 3.9+)
# This combines both into one master list for the loop
# Run validation and collect results
all_envs = environments_moretimout | environments
tasks = []

for env_name, url_list in all_envs.items():
    for url in url_list:
        timeout_val = 900 if url in environments_moretimout.get(env_name, []) else 10
        tasks.append((env_name, url, timeout_val))
print(f"🚀 Checking {len(tasks)} URLs in parallel...")

# 2. Worker function for the thread
def check_url(task):
    env_name, url, timeout_val = task
    code, status = get_status(url, timeout_val)
    return {
        'Prod Env': env_name, 
        'F5 and Node URLs': url, 
        'StatusCode': code, 
        'URLStatus': status
    }

# 3. Run Parallel Checks
# Use ThreadPoolExecutor for I/O-bound URL checking and to Execute in parallel with RETRIEVE in order
with ThreadPoolExecutor(max_workers=25) as executor:
    # executor.map preserves the order of the input 'tasks'
    unordered_results = list(executor.map(check_url, tasks))

# 4. Sort the results based on the preferred_order list
def sort_key(result):
    env_name = result['Prod Env']
    try:
        return preferred_order.index(env_name)
    except ValueError:
        return len(preferred_order) # Put unknown categories at the end

all_results = sorted(unordered_results, key=sort_key)


# 2. End Time (No Microseconds) & Duration Calculation in Hours, Minutes, and Seconds
end_ist = datetime.now(IST).replace(microsecond=0)
end_et = end_ist.astimezone(ET)
duration = end_ist - start_ist
total_seconds = int(duration.total_seconds())
# Breaking down total seconds
hours, remainder = divmod(total_seconds, 3600)
minutes, seconds = divmod(remainder, 60)
print(f"\n🏁 All Prod Env URL's Checking Finished at: {end_ist.strftime(fmt)}/{end_et.strftime(fmt)}")
duration_str = f"{hours}h {minutes}m {seconds}s"
