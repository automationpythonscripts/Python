tasks = []

for env_name, url_list in environments.items():
    for url in url_list:
        # Simplified: if the URL exists in the current list, use 10, else 5
        # Since you're iterating through the list, this will always be 10.
        timeout_val = 10 if url in url_list else 5
        tasks.append((env_name, url, timeout_val))
