def hybrid_encrypt(password: str, public_key) -> str:
    """Hybrid: RSA encrypts AES key + AES encrypts password"""
    # Generate random AES-256-GCM key
    aes_key = os.urandom(32)
    aesgcm = AESGCM(aes_key)
    nonce = os.urandom(12)

    # Encrypt password with AES
    ciphertext = aesgcm.encrypt(nonce, password.encode(), None)

    # Encrypt AES key with RSA public key (OAEP)
    encrypted_aes_key = public_key.encrypt(
        aes_key,
        padding.OAEP(
            mgf=padding.MGF1(algorithm=hashes.SHA256()),
            algorithm=hashes.SHA256(),
            label=None
        )
    )

    # Combine: encrypted_aes_key + nonce + ciphertext
    combined = encrypted_aes_key + nonce + ciphertext
    return b64encode(combined).decode()

