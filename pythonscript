def get_status(label, url):
    """Checks the URL and returns status metadata with centered HTML formatting"""
    # Initialize status_code for safety
    status_code = "UNKNOWN"
    
    # Helper to wrap text in a centering div
    center = lambda x: f'<div style="text-align: center;">{x}</div>'

    try:
        # Using a timeout and disabling SSL verification
        response = requests.get(url, timeout=10, verify=False)
        status_code = response.status_code
        
        if status_code == 200:
            # Consistent with "UP and Running" logic
            status_msg = (
                '<div style="color: green; font-weight: bold;">'
                'UP and Running'
                '</div>'
            )
        elif status_code == 404:
            # Logic: Check if the label implies a Node/JVM environment or a specific URL pattern
            if "NODE" in label.upper() or "WELLPOINT" in url.upper():
                status_msg = (
                    '<div style="color: green; font-weight: bold;">JVM UP</div>'
                    '<div style="color: red; font-weight: bold;">'
                    'but URL was DOWN<br>Context Root Not Found'
                    '</div>'
                )
            else:
                # Logic for standard F5 or General URL 404s
                status_msg = (
                    '<div style="color: red; font-weight: bold;">'
                    'URL was DOWN<br>Context Root Not Found'
                    '</div>'
                )           
        else:
            # Logic for other error codes (500, 403, etc.)
            status_msg = (
                f'<div style="color: red;">'
                f'DOWN ({status_code})<br>Service Unavailable'
                f'</div>'
            )
            
    except requests.exceptions.ConnectionError:
        status_code, status_msg = "FAILED", '<div style="color: red;">This site can’t be reached<br>URL Refused to connect</div>'
    except requests.exceptions.Timeout:
        status_code, status_msg = "TIMEOUT", '<div style="color: orange;">Server Timeout</div>'
    except Exception as e:
        status_code, status_msg = "ERROR", f'<div style="color: red;">{str(e)}</div>'

    return {
        "label": label, 
        "url": url, 
        "code": center(status_code), 
        "status": center(status_msg)
    }

def send_outlook_mail(results_data, duration_str, end_et):

    """Sends the formatted results via Outlook Desktop App categorized by Appwise group"""
    print("\nDrafting Outlook email...")

    now = datetime.now()
    hour = now.hour
    shift = "S1" if 6 <= hour < 15 else "S2" if 15 <= hour < 23 else "S3"
    date_today = now.strftime("%d %B %Y")
    fmt = "%Y-%m-%d %H:%M:%S"

    outlook = win32.Dispatch('outlook.application')
    mail = outlook.CreateItem(0)
    mail.To = 'Venkatesh.Sure@carelon.com'
    mail.CC = 'Venkatesh.Sure@carelon.com'
    mail.Subject = f'[SPS Monitoring Report] - Non-Prod Env WBS URLs Health Check Report - {shift} - {now.strftime("%d %B %Y")}'

    # Start HTML Body
    html_body = f"""
    <html>
    <body style="font-family: Calibri, sans-serif; color: #333;">
        <p>Hi Team,</p>
        <p>Please find the Non-Production <b style="color: #EAB003; font-weight:bold;">SPSCORESERVICES</b> Env, <b style="color: #EAB003; font-weight:bold;">PKM</b> Env and <b style="color: #EAB003; font-weight:bold;">MDM/MATCH</b> Env URLs Health Check report below.</p>
	<p>Non-Prod WBS Env URL's Checking Started at <i>{start_et.strftime(fmt)}</i>.</p>
    """

    # Iterate through Groups (SPS, PKM, etc.) and Subgroups (DEV, QA, etc.)
    for group, subgroups in results_data.items():
        # Main Blue Header
        #html_body += f'<h2 style="background-color: #004a99; color: white; padding: 10px; margin: 0 auto 5px auto; width: 50px; text-align: center;">{group}</h2>'
        html_body += f'<h2 style="background-color: #004a99; color: white; padding: 10px; margin: 0 auto 5px auto; display: table;">{group}</h2>'
        
        for sub, items in subgroups.items():
            # Yellow Subheader
            html_body += f'<h3 style="color: #EAB003; margin-top: 15px; border-bottom: 1px solid #ddd;">{sub} Env</h3>'
            
            html_body += """
            <table style="border-collapse: collapse; width: 72.5%; border: 1px solid #ddd; font-size: 13px; table-layout: fixed;">
                <tr style="background-color: #FF8C00;">
                    <th style="border:1px solid #ddd; padding:8px; text-align:left; width: 150px;">Environment</th>
                    <th style="border:1px solid #ddd; padding:8px; text-align:left;">URL Info</th>
                    <th style="border:1px solid #ddd; padding:8px; text-align:center; width: 80px;">StatusCode</th>
                    <th style="border:1px solid #ddd; padding:8px; text-align:center; width: 150px;">URL Status</th>
                </tr>"""
            
            for res in items:
                # Dynamic color coding based on status
                status_color = "#28a745" if "UP" in res['status'].upper() else "#dc3545"
                
                html_body += f"""
                <tr>
                    <td style="border:1px solid #ddd; padding:8px; font-weight: bold;">{res['label']}</td>
                    <!-- Reduced width and added overflow control -->
                    <td style="border:1px solid #ddd; padding:8px; text-align:left; width: 10px; overflow: hidden; text-overflow: ellipsis;">{res['url']}</td>
                    <td style="border:1px solid #ddd; padding:8px; text-align:center;">{res['code']}</td>
                    <td style="border:1px solid #ddd; padding:8px; text-align:center; color: {status_color}; font-weight: bold;">{res['status']}</td>
                </tr>"""
            
            html_body += "</table>"
 
    # Closing Footer
    html_body += f"""
    <p style="margin-top:20px;">
        Non-Prod WBS Env URL's Checking Finished at <i>{end_et.strftime(fmt)}</i>.<br>
        Non-Prod WBS Env URL's Status Health Check Verified within <i>{duration_str}.</i>
    </p>
    </body>
    </html>"""

    html_body += "<p>Regards,<br><b>Venkatesh Sure</b></p></body></html>"
    mail.HTMLBody = html_body
    mail.Send()
    print("Email sent successfully via Outlook.")

