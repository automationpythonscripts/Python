# ================== GENERATE EXCEL REPORT (FIXED) ==================
def generate_excel_report(results, total_urls=0, up_count=0, duration_str="", end_et=None):
    script_dir = os.path.dirname(os.path.abspath(__file__))
    now = datetime.now()
    shift = "S1" if 6 <= now.hour < 15 else "S2" if 15 <= now.hour < 23 else "S3"
    date_str = now.strftime("%Y%m%d")
    excel_filename = f"SPS_Non-Prod_HealthCheck_Report_{date_str}_{shift}.xlsx"
    excel_path = os.path.join(script_dir, excel_filename) # Full absolute path

    data = []
    for res in results:
        status_text = str(res['URLStatus'])
        clean_status = re.sub(r'<[^>]+>', '', status_text).strip()
        health = 'UP' if 'UP' in status_text or 'JVM UP' in status_text else 'DOWN'
        data.append({
            'Env Type': get_category(res['Non-Prod Env']),
            'F5 and Node URL Names': clean_env_name(res['Non-Prod Env']),
            'F5 and Node URLs': res['F5 and Node URLs'],
            'Status Code': res['StatusCode'],
            'URL Status': clean_status,
            'Health': health
        })

    df = pd.DataFrame(data)

    with pd.ExcelWriter(excel_path, engine='openpyxl') as writer:
        df.to_excel(writer, sheet_name='Health Check Report', index=False)
        ws = writer.sheets['Health Check Report']
        
        ws.insert_rows(1, 5)
        ws['A1'] = "SPS Non-Production Environment Health Check Report"
        ws['A1'].font = Font(size=14, bold=True)
        ws['A2'] = f"Report Generated: {end_et.strftime(fmt) if end_et else 'N/A'}"
        ws['A3'] = f"Total URLs: {total_urls} | UP: {up_count} | DOWN: {total_urls-up_count} | Success Rate: {round((up_count/total_urls)*100, 2)}% | Duration: {duration_str}"

        # Header formatting
        header_fill = PatternFill('solid', fgColor="366092")
        for cell in ws[7]:
            cell.fill = header_fill
            cell.font = Font(color="FFFFFF", bold=True)
            cell.alignment = Alignment(horizontal='center')

        # Color coding
        for row in range(8, 8 + len(df)):
            cell = ws.cell(row=row, column=6)
            cell.fill = PatternFill('solid', fgColor="C6EFCE") if cell.value == 'UP' else PatternFill('solid', fgColor="FFC7CE")

        # Auto adjust columns
        for col in ws.columns:
            max_length = max(len(str(cell.value or "")) for cell in col)
            col_letter = get_column_letter(col[0].column)
            ws.column_dimensions[col_letter].width = min(max_length + 3, 80)

    print(f"✅ Excel report generated successfully: {excel_filename}")
    return excel_path # Return full path

